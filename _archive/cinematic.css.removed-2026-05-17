  padding: clamp(20px, 3vw, 28px) !important;
  margin-bottom: 16px !important;
}

/* Security/Privacy/Terms/Cookies pages: content width */
body.f8-page .legal-body,
body.f8-page .privacy-body,
body.f8-page .terms-body,
body.f8-page .security-body {
  max-width: 720px !important;
  margin: 0 auto !important;
}

/* Glossary cards */
body.f8-page .glossary-card,
body.f8-page .pgc {
  background: rgba(10, 31, 58, 0.55) !important;
  border: 1px solid rgba(12, 201, 168, 0.12) !important;
  border-radius: 16px !important;
  padding: clamp(20px, 3vw, 28px) !important;
}

/* All cards: hover lift */
body.f8-page .hw:hover,
body.f8-page .tc:hover,
body.f8-page .uc:hover,
body.f8-page .sector:hover,
body.f8-page .pgc:hover,
body.f8-page .partner-card:hover,
body.f8-page .glossary-card:hover {
  transform: translateY(-4px) !important;
  border-color: rgba(12, 201, 168, 0.35) !important;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35) !important;
}

/* Image containment: prevent any image from breaking layout */
body.f8-page img {
  max-width: 100% !important;
  height: auto !important;
}
body.f8-page .photo-frame img,
body.f8-page figure img {
  border-radius: 16px !important;
  max-height: 400px !important;
  object-fit: cover !important;
}

/* Reveal animation: ensure sections are visible */
.reveal.is-visible,
body.f8-page .reveal {
  opacity: 1 !important;
  transform: translateY(0) !important;
}


/* ─── FIX: Carousel blackout — remove aspect-ratio constraint so content
   is never clipped during autoplay. The viewport overflow:hidden still hides
   the horizontal translateX animation of incoming slides, but vertical
   content (figcaption, product-frame chrome) is no longer cut off. ─── */
.crow-carousel-viewport {
  aspect-ratio: auto !important;
  overflow: hidden !important;
}
.crow-carousel-track {
  position: relative !important;
}
.crow-carousel-slide:not(.is-active) {
  position: absolute !important;
  inset: 0 !important;
  opacity: 0 !important;
  visibility: hidden !important;
  pointer-events: none !important;
}
.crow-carousel-slide.is-active {
  position: relative !important;
  opacity: 1 !important;
  visibility: visible !important;
}

/* ─── FIX: Product page responsive ─── */
@media (max-width: 768px) {
  .hero-product .wrap {
    padding: 0 20px !important;
  }
  .hero-product h1 {
    font-size: clamp(1.8rem, 7vw, 2.4rem) !important;
  }
  .hero-product .hero-sub {
    font-size: 15px !important;
  }
  .hero-product .hero-btns {
    flex-direction: column !important;
    align-items: stretch !important;
  }
  .hero-product .btn {
    width: 100% !important;
    text-align: center !important;
  }
}

/* ─── FIX: Pricing page mobile ─── */
@media (max-width: 768px) {
  .pricing-grid,
  .pc-grid {
    grid-template-columns: 1fr !important;
    gap: 16px !important;
  }
  .pc {
    padding: 24px !important;
  }
}

