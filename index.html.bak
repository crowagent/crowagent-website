<!-- VIS.B3 2026-05-20 — Audience deadlines band. Persona switcher + per-segment
     penalty banners lifted out of the hero and given their own dedicated
     section here (Stripe Connect persona-tabs pattern). The data-seg / data-for
     hooks remain the same so the existing segment-selector JS still drives
     visibility of the per-persona penalty banner. -->
<section class="hp-audience-band sv-section sv-section--secondary" aria-labelledby="hp-audience-heading">
  <div class="sv-container sv-container--standard sv-stack sv-stack--align-center sv-stack--gap-6">
    <div class="sv-stack sv-stack--align-center sv-stack--gap-3">
      <span class="sv-eyebrow">For your role</span>
      <h2 id="hp-audience-heading" class="sv-h2">A deadline that matters to you</h2>
      <p class="sv-text-secondary hp-audience-sub">Pick your role to see the live regulatory clock and the relevant CrowAgent engine.</p>
    </div>
    <div class="segment-selector segment-selector--prominent hp-audience-tabs" role="tablist" aria-label="I am a...">
      <button class="seg-btn active" data-seg="cyber" data-persona="cyber" role="tab" aria-selected="true" aria-controls="hero-countdown-panel" tabindex="0">IT &amp; Cyber Lead</button>
      <button class="seg-btn" data-seg="finance" data-persona="finance" role="tab" aria-selected="false" aria-controls="hero-countdown-panel" tabindex="-1">Finance &amp; AR Lead</button>
      <button class="seg-btn" data-seg="supplier" data-persona="bid" role="tab" aria-selected="false" aria-controls="hero-countdown-panel" tabindex="-1">Public-sector Supplier</button>
      <button class="seg-btn" data-seg="csrd" data-persona="sustainability" role="tab" aria-selected="false" aria-controls="hero-countdown-panel" tabindex="-1">Sustainability / CSRD</button>
      <button class="seg-btn" data-seg="landlord" data-persona="property" role="tab" aria-selected="false" aria-controls="hero-countdown-panel" tabindex="-1">Commercial Landlord</button>
      <button class="seg-btn" data-seg="sme" data-persona="sme" role="tab" aria-selected="false" aria-controls="hero-countdown-panel" tabindex="-1">VSME-eligible SME</button>
    </div>
    <div class="hp-audience-banners">
      <div class="hero-penalty-banner seg-text" data-for="cyber" role="status">
        <span class="hero-penalty-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
        <span class="hero-penalty-text"><strong>MFA mandatory</strong> on cloud admin accounts under Cyber Essentials v3.3 (Danzell), in force 27 April 2026. SMS-based MFA no longer accepted.</span>
      </div>
      <div class="hero-penalty-banner seg-text" data-for="landlord" role="status" hidden>
        <span class="hero-penalty-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></span>
        <span class="hero-penalty-text">Commercial properties failing Band C by 2028 face fines up to <strong>£150,000</strong>, rateable-value basis per SI 2015/962 reg 38.</span>
      </div>
      <div class="hero-penalty-banner seg-text" data-for="finance" role="status" hidden>
        <span class="hero-penalty-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>
        <span class="hero-penalty-text"><strong>Always in force.</strong> Late Payment of Commercial Debts (Interest) Act 1998 entitles you to base + 8% interest plus £40/£70/£100 statutory compensation per overdue invoice.</span>
      </div>
      <div class="hero-penalty-banner seg-text" data-for="sme" role="status" hidden>
        <span class="hero-penalty-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span>
        <span class="hero-penalty-text"><strong>EFRAG VSME 2024 ready for use.</strong> Voluntary SME standard with Module B (Basic) plus optional Module C (Comprehensive). Use it now to get ahead of supply-chain ESG requests.</span>
      </div>
    </div>
  </div>
</section>

<!-- SF30 2026-05-18 — hero-demo-block + product carousel + use-cases moved out of #hero into their own section, per spec section 7. -->
<section class="hero-demo-section section-padding" aria-labelledby="hero-demo-heading">
  <div class="wrap container-wide">

    <!-- SF-3 2026-05-17 — Stripe-grade looping product demo (animated SVG).
         Premium full-bleed slot between the hero text + the 5-slide carousel.
         Wraps the animated dashboard SVG in a Stripe 24px device-chrome with
         the two-layer shadow recipe. Has its own section-level reveal so
         ScrollTrigger fades it in cleanly. -->
    <!-- SF46 batch #2 2026-05-20 — multi-scene SVG cycle. 4 scenes × 7s = 28s
         looped walkthrough, mirroring a real product video until an AI-generated
         video asset drops in. Drives home the "pain → plan" arc via the existing
         how-step-*.svg vignettes. Pauses on hover / focus / hidden-tab; obeys
         prefers-reduced-motion (no auto-rotation, scene 1 stays visible). -->
    <div class="hero-demo-block reveal" id="home-demo-cycle">
      <div class="hero-demo-eyebrow ca-eyebrow">Live walkthrough · 28-second loop</div>
      <h2 class="hero-demo-h2">See CrowAgent across compliance in 28 seconds</h2>
      <p class="hero-demo-sub">From pain to plan: upload your portfolio, cross-check the frameworks, draft the report, ship to every stakeholder. A short, looping tour of the platform.</p>
      <!-- AF.5 2026-05-20 — CINEMATIC WALKTHROUGH (GSAP pan-and-zoom):
           Replaces the SVG scene cycle with 5 high-fidelity framed PNG
           screenshots animated by GSAP. The .sv-media-frame primitive
           supplies the Stripe-style browser chrome + edge highlight.
           Reduced-motion users see scene 1 only (no motion). -->
      <div id="cinematic-walkthrough" class="cinematic-walkthrough sv-media-frame" role="img" aria-label="Cinematic walkthrough of CrowAgent — five scenes panning across the live product">
        <div class="cinematic-walkthrough__stage">
          <img class="cinematic-scene is-active" data-scene="1" src="/Assets/marketing-screenshots/01-dashboard-dark-framed.png" alt="" decoding="async">
          <img class="cinematic-scene"           data-scene="2" src="/Assets/marketing-screenshots/02-epc-check-dark-framed.png" alt="" decoding="async">
          <img class="cinematic-scene"           data-scene="3" src="/Assets/marketing-screenshots/03-crowmark-dark-framed.png" alt="" decoding="async">
          <img class="cinematic-scene"           data-scene="4" src="/Assets/marketing-screenshots/04-csrd-checker-dark-framed.png" alt="" decoding="async">
          <img class="cinematic-scene"           data-scene="5" src="/Assets/marketing-screenshots/05-analytics-dark-framed.png" alt="" decoding="async">
        </div>
        <div class="home-demo-cycle__caption">
          <span class="home-demo-cycle__num" aria-hidden="true">01</span>
          <span class="home-demo-cycle__label" aria-live="polite">Upload your portfolio</span>
        </div>
      </div>
      <ol class="home-demo-cycle__dots" role="tablist" aria-label="Walkthrough scene selector">
        <li role="presentation"><button type="button" class="home-demo-cycle__dot is-active" role="tab" aria-selected="true" data-scene-target="1" aria-label="Scene 1 of 4: Upload your portfolio"></button></li>
        <li role="presentation"><button type="button" class="home-demo-cycle__dot" role="tab" aria-selected="false" data-scene-target="2" aria-label="Scene 2 of 4: Cross-check frameworks"></button></li>
        <li role="presentation"><button type="button" class="home-demo-cycle__dot" role="tab" aria-selected="false" data-scene-target="3" aria-label="Scene 3 of 4: Draft compliance reports"></button></li>
        <li role="presentation"><button type="button" class="home-demo-cycle__dot" role="tab" aria-selected="false" data-scene-target="4" aria-label="Scene 4 of 4: Ship to every stakeholder"></button></li>
      </ol>
    </div>

    <!-- CAROUSEL / USE-CASES SECTION -->
    <div class="hero-visual">
        <section class="crow-carousel" data-autoplay="true" data-interval="6000" aria-roledescription="carousel" aria-label="index product mockups">
  <div class="crow-carousel-viewport" aria-live="polite">
    <div class="crow-carousel-track">
      <div class="crow-carousel-slide is-active" role="group" aria-roledescription="slide" aria-label="1 of 5" aria-hidden="false">
        <figure>
          <div class="product-frame">
            <div class="product-frame-chrome" aria-hidden="true">
              <span class="product-frame-dot d-r"></span>
              <span class="product-frame-dot d-y"></span>
              <span class="product-frame-dot d-g"></span>
              <span class="product-frame-url">app.crowagent.ai/dashboard</span>
            </div>
            <!-- SF-3 2026-05-17: carousel slide 1 reverted to dashboard screenshot.
                 The animated dashboard SVG now lives in the standalone .hero-demo-block
                 above the carousel. Carousel = product UI gallery; hero demo = looping
                 live preview. Two complementary surfaces, no redundancy. -->
            <img loading="lazy" src="/Assets/screenshots/dashboard-1200.webp" srcset="/Assets/screenshots/dashboard-600.webp 600w, /Assets/screenshots/dashboard-1200.webp 1200w, /Assets/screenshots/dashboard-2400.webp 2400w" sizes="(max-width: 768px) 100vw, 50vw" alt="Unified portfolio dashboard across every product" width="1600" height="900" decoding="async" fetchpriority="high" class="crow-carousel-img">
          </div>
          <figcaption>Unified portfolio dashboard across every product</figcaption>
        </figure>
      </div>
      <div class="crow-carousel-slide" role="group" aria-roledescription="slide" aria-label="2 of 5" aria-hidden="true">
        <figure>
          <div class="product-frame">
            <div class="product-frame-chrome" aria-hidden="true">
              <span class="product-frame-dot d-r"></span>
              <span class="product-frame-dot d-y"></span>
              <span class="product-frame-dot d-g"></span>
              <span class="product-frame-url">app.crowagent.ai/core/retrofit</span>
            </div>
            <img src="/Assets/screenshots/epc-check.webp" alt="Live EPC gap analysis and retrofit planning (CrowAgent Core)" width="1600" height="900" loading="lazy" decoding="async" class="crow-carousel-img">
          </div>
          <figcaption>Live EPC gap analysis and retrofit planning (Core)</figcaption>
        </figure>
      </div>
      <div class="crow-carousel-slide" role="group" aria-roledescription="slide" aria-label="3 of 5" aria-hidden="true">
        <figure>
          <div class="product-frame">
            <div class="product-frame-chrome" aria-hidden="true">
              <span class="product-frame-dot d-r"></span>
              <span class="product-frame-dot d-y"></span>
              <span class="product-frame-dot d-g"></span>
              <span class="product-frame-url">app.crowagent.ai/crowmark</span>
            </div>
            <img src="/Assets/screenshots/crowmark.webp" alt="AI-assisted bid narrative drafting (CrowMark)" width="1600" height="900" loading="lazy" decoding="async" class="crow-carousel-img">
          </div>
          <figcaption>AI-assisted bid narrative drafting (CrowMark)</figcaption>
        </figure>
      </div>
      <div class="crow-carousel-slide" role="group" aria-roledescription="slide" aria-label="4 of 5" aria-hidden="true">
        <figure>
          <div class="product-frame">
            <div class="product-frame-chrome" aria-hidden="true">
              <span class="product-frame-dot d-r"></span>
              <span class="product-frame-dot d-y"></span>
              <span class="product-frame-dot d-g"></span>
              <span class="product-frame-url">app.crowagent.ai/analytics</span>
            </div>
            <img src="/Assets/screenshots/analytics.webp" alt="Unified analytics across the compliance estate (CrowCyber)" width="1600" height="900" loading="lazy" decoding="async" class="crow-carousel-img">
          </div>
          <figcaption>Unified analytics across the compliance estate (CrowCyber)</figcaption>
        </figure>
      </div>
      <div class="crow-carousel-slide" role="group" aria-roledescription="slide" aria-label="5 of 5" aria-hidden="true">
        <figure>
          <div class="product-frame">
            <div class="product-frame-chrome" aria-hidden="true">
              <span class="product-frame-dot d-r"></span>
              <span class="product-frame-dot d-y"></span>
              <span class="product-frame-dot d-g"></span>
              <span class="product-frame-url">app.crowagent.ai/csrd-checker</span>
            </div>
            <img src="/Assets/screenshots/csrd-checker.webp" alt="Omnibus I CSRD applicability checker (free tool)" width="1600" height="900" loading="lazy" decoding="async" class="crow-carousel-img">
          </div>
          <figcaption>Omnibus I CSRD applicability checker (free tool)</figcaption>
        </figure>
      </div>
    </div>
  </div>
  <div class="crow-carousel-controls">
    <button class="crow-carousel-prev" aria-label="Previous slide" type="button"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg></button>
    <div class="crow-carousel-dots" role="tablist" aria-label="Slide selector">
      <button role="tab" aria-selected="true" tabindex="0" aria-label="Slide 1" type="button"></button>
      <button role="tab" aria-selected="false" tabindex="-1" aria-label="Slide 2" type="button"></button>
      <button role="tab" aria-selected="false" tabindex="-1" aria-label="Slide 3" type="button"></button>
      <button role="tab" aria-selected="false" tabindex="-1" aria-label="Slide 4" type="button"></button>
