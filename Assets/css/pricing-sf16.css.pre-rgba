/* ARCH-3 Pass 1 (2026-05-21): wrapped in @layer overrides */
@layer overrides {
/* SF46 Y1 (2026-05-19) — Wrapped in @layer overrides.
   !important preserved (later layer beats earlier for important rules).
   Incremental drop-!important work will follow with visual-regression. */
@layer overrides {

/* =====================================================================
   pricing-sf16.css  —  Task 8: Pricing page premium polish
   2026-05-18.  Scoped to body.f8-pricing so global pages are untouched.

   Rules target BOTH the canonical class names from the SF-16 spec
   (.pricing-card.popular / .ca-popular-badge / .faq-answer) AND the
   actual existing CrowAgent class names already on the page
   (.pgc.pgc-pop / .pgc-badge / details > .f10-faq-answer) so that the
   selectors actually take effect against the live markup.
   ===================================================================== */

/* --------------------------------------------------------------------
   8a — Popular Card Differentiation
   -------------------------------------------------------------------- */
body.f8-pricing .pricing-card.popular,
body.f8-pricing .pgc.pgc-pop {
  border: 1.5px solid var(--teal);
  box-shadow: 0 0 0 2px var(--teal), 0 1.5rem 3rem rgba(0, 212, 170, 0.15);
  transform: translateY(-8px);
  background: linear-gradient(135deg, var(--surf2) 0%, var(--surf2) 100%);
  z-index: var(--z-content);
  position: relative;
}

body.f8-pricing .pricing-card.popular .ca-popular-badge,
body.f8-pricing .pgc.pgc-pop .ca-popular-badge {
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--teal);
  color: var(--bg);
  font-size:var(--font-size-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  padding:var(--space-1) 0.875rem;
  border-radius:var(--radius-full);
  text-transform: uppercase;
  line-height: 1.2;
  white-space: nowrap;
  box-shadow: 0 0.25rem 0.75rem rgba(0, 212, 170, 0.35);
  z-index: var(--z-content);
}

/* Suppress the legacy in-card badge on cards that now carry the
   canonical .ca-popular-badge so the two pills don't stack. */
body.f8-pricing .pgc.pgc-pop .ca-popular-badge + .pgc-badge {
  display: none;
}

@media (max-width:calc(768*0.0625rem)) {
  body.f8-pricing .pricing-card.popular,
  body.f8-pricing .pgc.pgc-pop {
    transform: none;
  }
}

/* --------------------------------------------------------------------
   8b — Billing toggle (Monthly / Annual)
   Track min-height 3.25rem, knob 28x28, spring easing, labels 0.9375rem/500.
   -------------------------------------------------------------------- */
body.f8-pricing .toggle-row,
body.f8-pricing .toggle-row--premium {
  min-height:calc(52*0.0625rem);
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
}

body.f8-pricing .ttrack {
  min-height:calc(52*0.0625rem);
  height:calc(36*0.0625rem);
  width:calc(68*0.0625rem);
  position: relative;
  border-radius:var(--radius-full);
  display: inline-flex;
  align-items: center;
  padding: 0 0.25rem;
  cursor: pointer;
  transition: background 320ms var(--ease-spring);
}

body.f8-pricing .ttrack .tthumb {
  width:calc(28*0.0625rem);
  height:calc(28*0.0625rem);
  border-radius: 50%;
  background: var(--white);
  box-shadow: 0 2px 0.375rem rgba(0, 0, 0, 0.25);
  transition: transform 360ms var(--ease-spring);
  will-change: transform;
}

body.f8-pricing .ttrack[aria-checked="true"] .tthumb {
  transform: translateX(2rem);
}

body.f8-pricing .toggle-label,
body.f8-pricing .tl {
  font-size:var(--font-size-base);
  font-weight: 500;
  letter-spacing: 0.005em;
  line-height: 1.4;
}

/* --------------------------------------------------------------------
   8c — Comparison table
   -------------------------------------------------------------------- */
body.f8-pricing .comparison-table {
  width: 100%;
  border-collapse: collapse;
}

body.f8-pricing .comparison-table th {
  font-size:var(--font-size-xs);
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.5);
  padding:var(--space-3) 1rem;
  text-align: left;
}

body.f8-pricing .comparison-table td {
  padding:0.875rem 1rem;
  border-bottom:calc(1*0.0625rem) solid rgba(255, 255, 255, 0.07);
  font-size:var(--font-size-base);
  color: rgba(255, 255, 255, 0.80);
}

body.f8-pricing .comparison-table tr:hover td {
  background: var(--white-03);
}

body.f8-pricing .comparison-table .check {
  color: var(--teal);
  font-size:var(--font-size-md);
}

body.f8-pricing .comparison-table .dash {
  color: rgba(255, 255, 255, 0.20);
}

/* --------------------------------------------------------------------
   8d — FAQ accordion
   The page uses native <details> with a .f10-faq-answer wrapper.
   Native <details> handles open/close — we just need the smooth
   transition shape. .open is also accepted for any non-<details>
   accordions that may share the page.
   -------------------------------------------------------------------- */
body.f8-pricing .faq-answer,
body.f8-pricing .f10-pricing-faq details > .f10-faq-answer {
  overflow: hidden;
  max-height: 0;
  transition: max-height 320ms var(--ease-standard);
}

body.f8-pricing .faq-answer.open,
body.f8-pricing .f10-pricing-faq details[open] > .f10-faq-answer {
  max-height:calc(600*0.0625rem);
}

/* ─── SF26-C — pricing toggle (Monthly / Annual / Save 10%) sizing fix
   ───────────────────────────────────────────────────────────────────
   User reported drag-button alignment + sizing issue. Track was 68×52
   (too short relative to a 1.75rem knob), knob vertically not centered,
   slide distance too narrow to feel premium. Resize to proper toggle
   proportions matching the SF18 ENH spec: 56×32 track, 24×24 knob,
   1.75rem slide distance, spring easing. Vertically pin knob centre. */
body.f8-pricing .toggle-row {
  gap: var(--space-3);
  align-items: center;
  background: rgba(15, 34, 64, 0.55);
  border:var(--border-hairline) solid var(--white-08);
  padding:var(--space-2-5) 1.125rem;
  border-radius:var(--radius-full);
}
body.f8-pricing .toggle-row .ttrack {
  width:calc(56*0.0625rem);
  height:calc(32*0.0625rem);
  background: var(--white-08);
  border:var(--border-hairline) solid rgba(255, 255, 255, 0.12);
  border-radius:var(--radius-full);
  position: relative;
  cursor: pointer;
  padding: 0;
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  transition: background 220ms ease, border-color 220ms ease;
}
body.f8-pricing .toggle-row .ttrack:hover {
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(255, 255, 255, 0.20);
}
body.f8-pricing .toggle-row .ttrack[aria-checked="true"] {
  background: rgba(0, 212, 170, 0.20);
  border-color: rgba(0, 212, 170, 0.45);
}
body.f8-pricing .toggle-row .ttrack .tthumb {
  position: absolute;
  top: 50%;
  left:calc(3*0.0625rem);
  width:calc(24*0.0625rem);
  height:calc(24*0.0625rem);
  border-radius:var(--radius-full);
  background: var(--white);
  transform: translateY(-50%);
  transition: transform 320ms var(--ease-spring), background 220ms ease;
  box-shadow: 0 2px 0.375rem rgba(0, 0, 0, 0.35);
}
body.f8-pricing .toggle-row .ttrack[aria-checked="true"] .tthumb {
  transform: translate(1.625rem, -50%);
  background: var(--teal);
}
body.f8-pricing .toggle-row .toggle-label {
  font-family: var(--font-display, "Inter"), sans-serif;
  font-size:var(--font-size-base);
  font-weight: 500;
  color: rgba(255, 255, 255, 0.55);
  cursor: pointer;
  transition: color 180ms ease;
}
body.f8-pricing .toggle-row .toggle-label.is-active-label {
  color: var(--color-text-primary, var(--white));
  font-weight: 600;
}
body.f8-pricing .toggle-row .toggle-savings-badge {
  padding:var(--space-1) 0.625rem;
  font-size:var(--font-size-xs);
  font-weight: 700;
  letter-spacing: 0.06em;
  background: rgba(0, 212, 170, 0.15);
  border:var(--border-hairline) solid rgba(0, 212, 170, 0.40);
  color: var(--teal);
  border-radius:var(--radius-full);
}
@media (max-width:calc(480*0.0625rem)) {
  body.f8-pricing .toggle-row { padding:var(--space-2) 0.875rem; gap: var(--space-2); }
  body.f8-pricing .toggle-row .ttrack { width:calc(48*0.0625rem); height:calc(28*0.0625rem); }
  body.f8-pricing .toggle-row .ttrack .tthumb { width:calc(20*0.0625rem); height:calc(20*0.0625rem); left:calc(3*0.0625rem); }
  body.f8-pricing .toggle-row .ttrack[aria-checked="true"] .tthumb { transform: translate(1.25rem, -50%); }
}
/* end SF26-C ───────────────────────────────────────────────────────── */

/* ─── SF27-A · Start Pro trial button — restore teal background
   Base .pgc-cta sets bg:var(--teal) (styles.css:831) but later overrides
   strip it back to transparent. .pgc-cta:not(.pgc-cta-out) is the primary
   teal-filled CTA in pricing cards. Force teal bg + obsidian text + visible. */
body.f8-pricing .pgc-cta:not(.pgc-cta-out),
body.f8-pricing .pgc-pop .pgc-cta {
  background: linear-gradient(180deg, var(--teal) 0%, var(--teal-d) 100%);
  color: var(--bg);
  border:var(--border-hairline) solid var(--teal);
  font-weight: 700;
  box-shadow:
    0 0 0 1px rgba(0, 212, 170, 0.50) inset,
    0 2px 0.375rem rgba(0, 0, 0, 0.25);
}
body.f8-pricing .pgc-cta:not(.pgc-cta-out):hover,
body.f8-pricing .pgc-pop .pgc-cta:hover {
  background: linear-gradient(180deg, var(--teal) 0%, var(--teal-d) 100%);
  box-shadow:
    0 0 0 1px rgba(0, 212, 170, 0.65) inset,
    0 0 1.25rem rgba(0, 212, 170, 0.30);
  transform: translateY(-1px);
}

/* ─── SF27-B · Comparison table double-tick + double-dash fix
   Base CSS at styles.css:22914 adds an SVG ::before tick AND sets the
   .check element font-size:0 to hide the original ✓ text. The agent's
   earlier pricing-sf16.css rule at line 134 then overrode font-size:var(--font-size-md)
   which re-showed the ✓ text → double tick.
   Same pattern for .dash: ::after adds em-dash AND the cell text "-"
   stays visible → "- —".
   Fix: hide original text via font-size:0 on the wrapper, but keep the
   pseudo-element at proper visual size via display:inline-block + width. */
body.f8-pricing .comparison-table .check {
  font-size: 0; /* hide original ✓ text */
  line-height: 0;
  text-align: center;
  white-space: nowrap;
}
body.f8-pricing .comparison-table .check::before {
  font-size:var(--font-size-md);
  line-height: 1;
  display: inline-block;
  vertical-align: middle;
}
body.f8-pricing .comparison-table .dash {
  font-size: 0;
  line-height: 0;
  text-align: center;
  white-space: nowrap;
}
body.f8-pricing .comparison-table .dash::after {
  font-size:var(--font-size-md);
  line-height: 1;
  color: rgba(255, 255, 255, 0.30);
  display: inline-block;
  vertical-align: middle;
}
/* end SF27-A + SF27-B ─────────────────────────────────────────────────── */


/* ═══════════════════════════════════════════════════════════════════════════
   ENH-17b 2026-05-18 — Pricing enterprise row + trust line
   Dedicated visible enterprise tier block (was previously buried in a fine-
   print paragraph). Surfaces SSO/SLA/£999+ tier, plus a 7-pill trust row.
   ═══════════════════════════════════════════════════════════════════════════ */

body.f8-pricing .pricing-enterprise-row {
  padding-block: clamp(3rem, 6vw, 5rem);
}

body.f8-pricing .pricing-enterprise-card {
  display: grid;
  grid-template-columns: minmax(0, 1.6fr) minmax(17.5rem, 0.9fr);
  gap: clamp(2rem, 4vw, 4rem);
  align-items: start;
  background: linear-gradient(135deg, rgba(13, 40, 71, 0.65) 0%, rgba(10, 22, 40, 0.85) 100%);
  border:var(--border-hairline) solid var(--border2, var(--teal-20));
  border-radius:1.25rem;
  padding: clamp(1.75rem, 3.5vw, 3rem);
  box-shadow: 0 1.5rem 4rem -24px rgba(0, 0, 0, 0.45);
}

@media (max-width:calc(768*0.0625rem)) {
  body.f8-pricing .pricing-enterprise-card {
    grid-template-columns: 1fr;
    padding:var(--space-6);
  }
}

body.f8-pricing .pricing-enterprise-title {
  font-family: var(--font-display, 'Plus Jakarta Sans'), sans-serif;
  font-weight: 700;
  font-size: clamp(1.375rem, 2.4vw, 1.875rem);
  line-height: 1.18;
  color: var(--cloud);
  margin:var(--space-2) 0 1rem;
  max-width: 28ch;
}

body.f8-pricing .pricing-enterprise-desc {
  font-family: var(--font-body, 'Inter'), sans-serif;
  font-size:var(--font-size-base);
  line-height: 1.55;
  color: var(--steel);
  margin: 0 0 1.125rem;
  max-width: 56ch;
}
body.f8-pricing .pricing-enterprise-desc strong {
  color: var(--cloud);
  font-weight: 700;
}

body.f8-pricing .pricing-enterprise-features {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  gap: var(--space-2);
}
body.f8-pricing .pricing-enterprise-features li {
  position: relative;
  padding-left: var(--space-6);
  font-size:var(--font-size-base);
  line-height: 1.5;
  color: var(--steel);
}
body.f8-pricing .pricing-enterprise-features li::before {
  content: "";
  position: absolute;
  left: 0;
  top:calc(7*0.0625rem);
  width:calc(14*0.0625rem);
  height:calc(8*0.0625rem);
  border-left:calc(2*0.0625rem) solid var(--teal);
  border-bottom:calc(2*0.0625rem) solid var(--teal);
  transform: rotate(-45deg);
}

body.f8-pricing .pricing-enterprise-cta {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
body.f8-pricing .pricing-enterprise-cta .btn {
  width: 100%;
  justify-content: center;
}
body.f8-pricing .pricing-enterprise-meta {
  font-family: var(--font-body, 'Inter'), sans-serif;
  font-size:var(--font-size-sm);
  color: var(--mist);
  margin:var(--space-1-5) 0 0;
  text-align: center;
}

body.f8-pricing .pricing-trust-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: var(--space-2) 1rem;
  margin-top: clamp(1.5rem, 3vw, 2.25rem);
}
body.f8-pricing .pricing-trust-pill {
  /* SF46 batch #3 2026-05-20 — premium translucent teal chip per founder spec. */
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-family: var(--font-body, 'Inter'), sans-serif;
  font-size:var(--font-size-sm);
  color: var(--teal);
  background: rgba(12, 201, 168, 0.10);
  border:var(--border-hairline) solid var(--teal-20);
  border-radius:var(--radius-pill);
  padding:var(--space-1-5) 0.75rem;
  line-height: 1;
  white-space: nowrap;
}
body.f8-pricing .pricing-trust-pill svg {
  color: var(--teal);
  flex-shrink: 0;
  vertical-align: middle;
}

} /* end @layer overrides */

/* ═══════════════════════════════════════════════════════════════════════
   SF46 batch #3 — Pricing page premium upgrade (2026-05-20)
   Founder directive: institutional-grade polish. CSS-only. Scoped to
   body.f8-pricing so other pages stay untouched. No new !important.

   IMPORTANT: these rules live OUTSIDE @layer overrides so they compete
   in the default unlayered cascade with .ms-card-lift / .pgc base rules.
   Higher per-selector specificity wins normally.
   ═══════════════════════════════════════════════════════════════════════ */

/* B3.1 — Glassmorphic reflective-edge pricing cards (.pgc) */
body.f8-pricing main .pgrid > .pgc {
  background: rgba(10, 31, 58, 0.40);
  backdrop-filter: blur(1.5rem);
  -webkit-backdrop-filter: blur(1.5rem);
  border:var(--border-hairline) solid var(--white-05);
  border-radius:1.5rem;
  transition: transform 280ms var(--ease-out, var(--ease-canonical)),
              background 280ms var(--ease-out, var(--ease-canonical)),
              box-shadow 280ms var(--ease-out, var(--ease-canonical)),
              border-color 280ms var(--ease-out, var(--ease-canonical));
}
body.f8-pricing main .pgrid > .pgc::before {
  /* Reflective gradient border via mask compositing. The padding-1px box
     is filled with the gradient; the inner box is masked out so only the
     1px ring remains visible — a true gradient border without an extra
     wrapper element. */
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding:0.0625rem;
  background: linear-gradient(135deg,
              rgba(255, 255, 255, 0.15) 0%,
              transparent 50%,
              rgba(12, 201, 168, 0.10) 100%);
  -webkit-mask:
    linear-gradient(var(--bg) 0 0) content-box,
    linear-gradient(var(--bg) 0 0);
  -webkit-mask-composite: xor;
          mask:
    linear-gradient(var(--bg) 0 0) content-box,
    linear-gradient(var(--bg) 0 0);
          mask-composite: exclude;
  pointer-events: none;
}
body.f8-pricing main .pgrid > .pgc:hover {
  transform: translateY(-8px);
  background: rgba(10, 31, 58, 0.70);
  box-shadow: 0 1.875rem 3.75rem -20px rgba(0, 0, 0, 0.50);
}
body.f8-pricing main .pgrid > .pgc.pgc-pop {
  border-color: var(--teal);
  box-shadow: 0 1.25rem 2.5rem var(--teal-15);
}
body.f8-pricing main .pgrid > .pgc.pgc-pop:hover {
  /* Compose hover lift WITH the persistent teal glow */
  box-shadow:
    0 1.875rem 3.75rem -20px rgba(0, 0, 0, 0.50),
    0 1.25rem 2.5rem var(--teal-15);
}

/* B3.2 — Tactile feedback on billing toggle + CTAs.
   The pricing page uses .ttrack as the toggle "track" (no .toggle-btn
   class exists in this DOM). We wire scale(0.97) on its :active so the
   knob "presses". A defensive .toggle-btn:active rule is included for
   any non-pricing surface that may carry it. */
body.f8-pricing .ttrack:active,
.toggle-btn:active {
  transform: scale(0.97);
  transition-duration: 80ms;
}
/* When the active state has been toggled, project a bright bg per the
   founder spec ("aggressively highlight the selected state"). */
.toggle-btn.active {
  background: var(--white);
  color: var(--bg);
}

/* B3.3 — Trust pills (.f10-trust-pill site-wide canonical) get premium
   translucent treatment. Site-wide so it ripples to any reuse, not just
   pricing. SVG icons baseline-aligned. */
.f10-trust-pill {
  background: rgba(12, 201, 168, 0.10);
  border:var(--border-hairline) solid var(--teal-20);
  color: var(--teal);
  border-radius:var(--radius-pill);
}
.f10-trust-pill svg,
.pricing-trust-pill svg {
  vertical-align: middle;
  flex-shrink: 0;
}

/* B3.4 — Comparison table modernisation: kill vertical column dividers,
   subtle row separators only, premium uppercase headers. */
body.f8-pricing .comparison-table th,
body.f8-pricing .comparison-table td {
  border-left: 0;
  border-right: 0;
}
body.f8-pricing .comparison-table tr {
  border-bottom:calc(1*0.0625rem) solid var(--white-05);
}
body.f8-pricing .comparison-table th {
  font-family: 'Plus Jakarta Sans', sans-serif;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 0.85rem;
}
} /* end @layer overrides */
