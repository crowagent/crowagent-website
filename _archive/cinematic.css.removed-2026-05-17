/* === CINEMATIC TRANSFORMATION v2.0 — Premium UI System === */
/* Inspired by: stripe.com, apple.com, notion.com, ads.google.com */
/* All colours via CSS custom properties — never hardcode hex */

:root {
  --cinematic-ease: cubic-bezier(0.16, 1, 0.3, 1);
  --cinematic-ease-out: cubic-bezier(0.33, 1, 0.68, 1);
  --cinematic-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --glass-bg: rgba(10, 31, 58, 0.55);
  --glass-bg-hover: rgba(10, 31, 58, 0.7);
  --glass-border: rgba(12, 201, 168, 0.12);
  --glass-border-hover: rgba(12, 201, 168, 0.35);
  --glass-blur: 24px;
  --space-section: clamp(64px, 8vw, 120px);
  --space-section-inner: clamp(40px, 5vw, 80px);
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.15);
  --shadow-md: 0 8px 32px rgba(0, 0, 0, 0.2);
  --shadow-lg: 0 20px 60px rgba(0, 0, 0, 0.35);
  --shadow-xl: 0 32px 80px rgba(0, 0, 0, 0.45);
  --shadow-glow: 0 0 40px rgba(12, 201, 168, 0.15);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --radius-pill: 100px;
}

/* Section Spacing (Luxury Whitespace) */
.section-padding,
.frameworks-grid-section,
.stats,
.how,
.products,
.sectors,
.trust,
.cta-band {
  padding-block: var(--space-section);
}

/* Hero Backdrop System */
.hero {
  position: relative;
  overflow: hidden;
  min-height: 92vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  padding-block: clamp(80px, 10vh, 140px);
}
.hero-mesh-canvas {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.7;
}
.hero-backdrop {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}
.hero-earth-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform-origin: 50% 50%;
  filter: saturate(0.85) brightness(0.85);
  will-change: transform;
}
.hero-backdrop-scrim {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse at 50% 40%,
    transparent 0%,
    rgba(4, 14, 26, 0.35) 45%,
    rgba(4, 14, 26, 0.88) 100%
  );
  z-index: 2;
}
.hero > .wrap,
.hero > .container-wide {
  position: relative;
  z-index: 10;
}
.hero-orb {
  will-change: transform;
  transition: transform 0.8s var(--cinematic-ease-out);
}


/* Sophisticated Scroll Reveals */
.reveal {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.9s var(--cinematic-ease),
              transform 0.9s var(--cinematic-ease);
}
.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-delay-1 { transition-delay: 0.08s; }
.reveal-delay-2 { transition-delay: 0.16s; }
.reveal-delay-3 { transition-delay: 0.24s; }
.reveal-delay-4 { transition-delay: 0.32s; }

/* Glassmorphism Card System */
.bento-card,
.product-full-block {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur));
  -webkit-backdrop-filter: blur(var(--glass-blur));
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: clamp(24px, 4vw, 40px);
  transition: transform 0.5s var(--cinematic-ease),
              box-shadow 0.5s var(--cinematic-ease),
              border-color 0.5s var(--cinematic-ease);
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}
.bento-card::before,
.product-full-block::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(
    600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
    rgba(12, 201, 168, 0.08) 0%,
    transparent 40%
  );
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  z-index: 0;
}
.bento-card:hover::before,
.product-full-block:hover::before {
  opacity: 1;
}
.bento-card:hover,
.product-full-block:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-lg), var(--shadow-glow);
  border-color: var(--glass-border-hover);
}

/* Products Bento Grid */
.products-bento {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(24px, 3vw, 32px);
  max-width: 1300px;
  margin: 0 auto;
}
.pc--bento-span {
  grid-column: span 1;
}

/* Product Full Block Layout */
.product-full-block {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(24px, 4vw, 48px);
  align-items: center;
}
.product-full-block-alt {
  direction: rtl;
}
.product-full-block-alt > * {
  direction: ltr;
}
.product-full-inner {
  position: relative;
  z-index: 1;
}
.product-full-visual {
  position: relative;
  z-index: 1;
}
.product-full-visual img {
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  transition: transform 0.5s var(--cinematic-ease);
}
.product-full-block:hover .product-full-visual img {
  transform: scale(1.02);
}


/* Story Shell (Scrollytelling) */
.story-shell {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 80px;
  align-items: start;
  padding: var(--space-section) 0;
}
.story-steps {
  display: flex;
  flex-direction: column;
  gap: 160px;
}
.story-step {
  opacity: 0.2;
  transition: opacity 0.8s var(--cinematic-ease);
}
.story-step.is-active { opacity: 1; }
.story-visual-wrap {
  position: sticky;
  top: 15vh;
  height: 600px;
  display: flex;
  align-items: center;
  perspective: 1000px;
}
.story-visual {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: rotateY(8deg) translateZ(-40px) scale(0.92);
  transition: opacity 0.9s var(--cinematic-ease),
              transform 0.9s var(--cinematic-ease);
}
.story-visual.is-active {
  opacity: 1;
  transform: rotateY(0) translateZ(0) scale(1);
}

/* Product Chrome Frame (Apple Style) */
.product-frame {
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: var(--shadow-xl);
  background: var(--bg);
}
.product-frame-chrome {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 18px;
  background: var(--surf);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.product-frame-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}
.product-frame-url {
  margin-left: 12px;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 11px;
  color: var(--mist);
}

/* Framework Cards — enhance existing styles.css treatment */
.framework-card {
  transition: transform 0.4s var(--cinematic-ease),
              box-shadow 0.4s var(--cinematic-ease),
              border-color 0.4s var(--cinematic-ease);
}
.framework-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}

/* Sector Cards — defer to styles.css, only enhance image treatment */
.sector img {
  width: calc(100% + 56px);
  margin: -32px -28px 16px;
  height: 180px;
  object-fit: cover;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transition: transform 0.6s var(--cinematic-ease);
}
.sector:hover img {
  transform: scale(1.05);
}

/* Trust Cards — enhance hover only */
.tc {
  transition: transform 0.4s var(--cinematic-ease),
              border-color 0.4s var(--cinematic-ease);
}
.tc:hover {
  transform: translateY(-4px);
}


/* How It Works Tabs — defer to styles.css for pill-based tab styling */
.how-tab:hover {
  color: var(--cloud);
}

/* How It Works Step Cards */
.hw-grid {
  display: grid;
  gap: clamp(16px, 2vw, 24px);
}
.hw-grid-2col {
  grid-template-columns: repeat(2, 1fr);
}
.hw {
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: clamp(20px, 3vw, 32px);
  transition: transform 0.3s var(--cinematic-ease),
              border-color 0.3s var(--cinematic-ease);
}
.hw:hover {
  transform: translateY(-3px);
  border-color: var(--glass-border-hover);
}
.hw-num {
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-size: 13px;
  font-weight: 700;
  color: var(--teal);
  margin-bottom: 12px;
}

/* Stats Section Premium */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: clamp(24px, 4vw, 48px);
  text-align: center;
}
.sc-num {
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 800;
  color: var(--teal);
  line-height: 1.1;
  margin-bottom: 8px;
}
.sc-lbl {
  font-size: clamp(0.85rem, 1.2vw, 1rem);
  color: var(--steel);
}

/* CTA Band Premium */
.triple-cta-section {
  background: linear-gradient(
    180deg,
    var(--surf) 0%,
    var(--bg) 100%
  );
  border-top: 1px solid var(--glass-border);
  border-bottom: 1px solid var(--glass-border);
}
.triple-cta-grid {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: clamp(24px, 3vw, 48px);
  align-items: center;
  max-width: 1300px;
  margin: 0 auto;
  padding: 0 clamp(20px, 5vw, 64px);
}
.triple-card {
  background: var(--glass-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: clamp(24px, 3vw, 32px);
}
.triple-cta-main {
  text-align: center;
  padding: clamp(32px, 4vw, 48px);
}

/* Magnetic Buttons */
[data-magnetic] {
  display: inline-flex;
  transition: transform 0.1s ease-out;
}

/* Button Premium Hover Enhancement */
.btn-primary-v2 {
  position: relative;
  overflow: hidden;
}
.btn-primary-v2::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.15) 0%,
    transparent 50%
  );
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}
.btn-primary-v2:hover::after {
  opacity: 1;
}
.btn-primary-v2:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(12, 201, 168, 0.3),
              0 0 0 1px rgba(12, 201, 168, 0.6);
}
.btn-secondary:hover {
  border-color: rgba(12, 201, 168, 0.4);
  background: rgba(12, 201, 168, 0.06);
  transform: translateY(-1px);
}

/* Use Case Cards */
.use-cases {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: clamp(16px, 2vw, 24px);
  margin-top: clamp(32px, 4vw, 48px);
}
.uc {
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: clamp(20px, 3vw, 28px);
  transition: transform 0.3s var(--cinematic-ease),
              border-color 0.3s var(--cinematic-ease);
}
.uc:hover {
  transform: translateY(-4px);
  border-color: var(--glass-border-hover);
}

/* Methodology Cards */
.methodology-4col {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: clamp(16px, 2vw, 24px);
}
.u-card {
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: clamp(24px, 3vw, 32px);
  transition: transform 0.3s var(--cinematic-ease),
              border-color 0.3s var(--cinematic-ease);
}
.u-card:hover {
  transform: translateY(-4px);
  border-color: var(--glass-border-hover);
}

/* Demo Widget Premium */
.demo-widget-card {
  background: var(--glass-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-lg);
  padding: clamp(24px, 3vw, 32px);
  margin-top: 24px;
}
.f10-try-now-card {
  background: var(--glass-bg);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: clamp(32px, 5vw, 56px);
}


/* Carousel Premium — Stripe/Apple-level redesign */
.crow-carousel {
  border-radius: var(--radius-xl);
  overflow: visible;
  position: relative;
}
.crow-carousel-viewport {
  overflow: hidden;
  border-radius: var(--radius-xl);
  position: relative;
}
.crow-carousel-track {
  position: relative;
}
.crow-carousel-slide {
  opacity: 0;
  transform: translateX(30px) scale(0.96);
  transition: opacity 0.8s var(--cinematic-ease),
              transform 0.8s var(--cinematic-ease);
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.crow-carousel-slide.is-active {
  opacity: 1;
  transform: translateX(0) scale(1);
  position: relative;
  pointer-events: auto;
}
.crow-carousel-slide figure {
  margin: 0;
}
.crow-carousel-slide figcaption {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 13px;
  color: var(--mist);
  text-align: center;
  margin-top: 12px;
  opacity: 0.8;
}
.crow-carousel-img {
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  width: 100%;
  height: auto;
  display: block;
}

/* Premium Chrome Frame for Carousel */
.crow-carousel .product-frame {
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5),
              0 8px 24px rgba(0, 0, 0, 0.3),
              inset 0 1px 0 rgba(255, 255, 255, 0.05);
  background: var(--bg);
  transition: box-shadow 0.5s var(--cinematic-ease),
              transform 0.5s var(--cinematic-ease);
}
.crow-carousel .product-frame:hover {
  box-shadow: 0 28px 80px rgba(0, 0, 0, 0.6),
              0 12px 32px rgba(0, 0, 0, 0.4),
              0 0 0 1px rgba(12, 201, 168, 0.15),
              inset 0 1px 0 rgba(255, 255, 255, 0.08);
  transform: translateY(-4px);
}
.crow-carousel .product-frame-chrome {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 18px;
  background: linear-gradient(180deg, var(--surf2) 0%, var(--surf) 100%);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}
.crow-carousel .product-frame-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  opacity: 0.9;
}
.crow-carousel .product-frame-url {
  margin-left: auto;
  font-family: var(--font-mono, 'JetBrains Mono', monospace);
  font-size: 11px;
  color: var(--mist);
  opacity: 0.7;
  background: rgba(0, 0, 0, 0.2);
  padding: 3px 10px;
  border-radius: var(--radius-sm);
}

/* Carousel Controls Premium */
.crow-carousel-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 24px;
  padding: 0 16px;
}
.crow-carousel-prev,
.crow-carousel-next {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  color: var(--cloud);
  cursor: pointer;
  transition: all 0.3s var(--cinematic-ease);
}
.crow-carousel-prev:hover,
.crow-carousel-next:hover {
  background: var(--glass-bg-hover);
  border-color: var(--glass-border-hover);
  transform: scale(1.1);
  box-shadow: 0 4px 16px rgba(12, 201, 168, 0.15);
}
.crow-carousel-dots {
  display: flex;
  gap: 8px;
  align-items: center;
}
.crow-carousel-dots [role="tab"] {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--mist);
  border: none;
  padding: 0;
  cursor: pointer;
  transition: all 0.4s var(--cinematic-ease);
  position: relative;
  opacity: 0.5;
}
.crow-carousel-dots [role="tab"][aria-selected="true"],
.crow-carousel-dots [role="tab"].is-active {
  background: var(--teal);
  opacity: 1;
  width: 24px;
  border-radius: var(--radius-pill);
  box-shadow: 0 0 8px rgba(12, 201, 168, 0.4);
}
.crow-carousel-pause {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: transparent;
  border: 1px solid var(--glass-border);
  color: var(--mist);
  cursor: pointer;
  transition: all 0.3s ease;
}
.crow-carousel-pause:hover {
  border-color: var(--glass-border-hover);
  color: var(--cloud);
}
.crow-carousel-pause .icon-play { display: none; }
.crow-carousel-pause[aria-pressed="true"] .icon-pause { display: none; }
.crow-carousel-pause[aria-pressed="true"] .icon-play { display: block; }

/* Section Dividers */
.section-divider {
  border: none;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    var(--glass-border) 20%,
    var(--glass-border) 80%,
    transparent 100%
  );
  margin: 0;
}

/* Contact Section */
.contact-section {
  text-align: center;
}
.contact-section-actions {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 24px;
}

/* Regulatory Footnotes */
.regulatory-footnotes {
  padding: 24px 0;
  border-top: 1px solid var(--glass-border);
  font-size: 13px;
  color: var(--mist);
}

/* Background Blending */
.section-blend-dark { background-color: var(--bg); transition: background-color 1s ease; }
.section-blend-teal { background-color: rgba(5, 32, 36, 0.5); transition: background-color 1s ease; }

/* Responsive: Tablet Landscape */
@media (max-width: 1024px) {
  .story-shell {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .story-visual-wrap {
    position: relative;
    top: auto;
    height: auto;
  }
  .product-full-block {
    grid-template-columns: 1fr;
  }
  .product-full-block-alt {
    direction: ltr;
  }
  .triple-cta-grid {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .hw-grid-2col {
    grid-template-columns: 1fr;
  }
}

/* Responsive: Tablet Portrait */
@media (max-width: 768px) {
  :root {
    --space-section: 48px;
  }
  .hero {
    min-height: 80vh;
    padding-block: 60px;
  }
  .frameworks-grid {
    grid-template-columns: 1fr;
  }
  .sector-grid {
    grid-template-columns: 1fr;
  }
  .stats-grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .use-cases {
    grid-template-columns: 1fr;
  }
}

/* Responsive: Mobile */
@media (max-width: 640px) {
  :root {
    --space-section: 40px;
  }
  .hero {
    min-height: 70vh;
    padding-block: 48px;
  }
  .products-bento {
    grid-template-columns: 1fr;
  }
  .tc-grid {
    grid-template-columns: 1fr;
  }
  .methodology-4col {
    grid-template-columns: 1fr;
  }
  .how-tabs {
    border-radius: var(--radius-lg);
    padding: 6px;
  }
  .how-tab {
    padding: 8px 12px;
    font-size: 11px;
  }
  .crow-carousel-prev,
  .crow-carousel-next {
    display: none;
  }
}

/* Reduced Motion */
@media (prefers-reduced-motion: reduce) {
  .reveal {
    opacity: 1;
    transform: none;
    transition: none;
  }
  .bento-card:hover,
  .product-full-block:hover,
  .framework-card:hover,
  .sector:hover,
  .tc:hover,
  .hw:hover,
  .uc:hover,
  .u-card:hover {
    transform: none;
  }
  .hero-earth-img {
    will-change: auto;
  }
  .story-step {
    opacity: 1;
  }
  .story-visual {
    opacity: 1;
    transform: none;
  }
}

/* === END CINEMATIC TRANSFORMATION v2.0 === */


/* ─── PREMIUM EFFECTS v2.1 ─── */

/* Gradient Text (Apple-style) */
.gradient-text,
.frameworks-grid-title {
  background: linear-gradient(
    135deg,
    var(--cloud) 0%,
    var(--teal) 50%,
    var(--cloud) 100%
  );
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradient-shift 8s ease infinite;
}
@keyframes gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

/* Animated Glow Border (Featured Cards) — pulsing teal glow */
.pc--featured {
  box-shadow: var(--shadow-md),
              0 0 20px rgba(12, 201, 168, 0.15),
              inset 0 0 0 1px rgba(12, 201, 168, 0.3);
  animation: glow-pulse 3s ease-in-out infinite;
}
@keyframes glow-pulse {
  0%, 100% { box-shadow: var(--shadow-md), 0 0 20px rgba(12, 201, 168, 0.1), inset 0 0 0 1px rgba(12, 201, 168, 0.2); }
  50% { box-shadow: var(--shadow-md), 0 0 40px rgba(12, 201, 168, 0.2), inset 0 0 0 1px rgba(12, 201, 168, 0.4); }
}

/* Scroll Progress Indicator */
.scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 0%;
  height: 3px;
  background: linear-gradient(90deg, var(--teal), rgba(12, 201, 168, 0.6));
  z-index: 9999;
  transition: width 0.1s linear;
  pointer-events: none;
}

/* Number Counter Animation */
.counter {
  display: inline-block;
  font-variant-numeric: tabular-nums;
}

/* Parallax Section Backgrounds */
.section-parallax {
  position: relative;
  overflow: hidden;
}
.section-parallax::before {
  content: '';
  position: absolute;
  inset: -20%;
  background: radial-gradient(
    ellipse at 30% 50%,
    rgba(12, 201, 168, 0.04) 0%,
    transparent 60%
  );
  pointer-events: none;
  will-change: transform;
}

/* Enhanced Carousel — active dot indicator */
.crow-carousel-dots [role="tab"][aria-selected="true"] {
  background: var(--teal);
  transform: scale(1);
}

/* Floating Glow Orbs (Section Decoration) */
.section-glow {
  position: relative;
}
.section-glow::after {
  content: '';
  position: absolute;
  width: 400px;
  height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(12, 201, 168, 0.06) 0%, transparent 70%);
  top: 50%;
  right: -200px;
  transform: translateY(-50%);
  pointer-events: none;
  animation: float-glow 12s ease-in-out infinite;
}
@keyframes float-glow {
  0%, 100% { transform: translateY(-50%) translateX(0); }
  50% { transform: translateY(-50%) translateX(-30px); }
}

/* Nav Scroll Progress Enhancement */
body.is-scrolled #ca-nav {
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

/* Smooth Section Tone Transitions */
.section-tone-0 {
  background: var(--bg);
}
.section-tone-1 {
  background: var(--surf);
  border-top: 1px solid rgba(12, 201, 168, 0.06);
  border-bottom: 1px solid rgba(12, 201, 168, 0.06);
}

/* Premium Focus States */
:focus-visible {
  outline: 2px solid var(--teal);
  outline-offset: 3px;
  border-radius: 4px;
}

/* Product Icon Chip Glow */
.product-icon-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(12, 201, 168, 0.1);
  border: 1px solid rgba(12, 201, 168, 0.2);
  margin-right: 12px;
  vertical-align: middle;
}

/* Back to Top Button Premium */
#back-to-top {
  position: fixed;
  bottom: 32px;
  right: 32px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  color: var(--teal);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.4s var(--cinematic-ease),
              transform 0.4s var(--cinematic-ease),
              border-color 0.3s ease;
  z-index: 100;
}
#back-to-top:hover {
  border-color: var(--glass-border-hover);
  transform: translateY(-2px);
}
body.is-scrolled #back-to-top {
  opacity: 1;
  transform: translateY(0);
}

/* Reduced Motion Override for Premium Effects */
@media (prefers-reduced-motion: reduce) {
  .gradient-text,
  .u-h2-display,
  .frameworks-grid-title {
    animation: none;
    background-size: 100% 100%;
  }
  .pc--featured::after,
  .product-full-block.pc--featured::after {
    animation: none;
  }
  .section-glow::after {
    animation: none;
  }
  .crow-carousel-dots [role="tab"][aria-selected="true"]::after {
    animation: none;
  }
}


