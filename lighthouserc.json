{
  "_doc": "U-10 LAYER 4 — Lighthouse CI. Runs against the local dev server (default :8083) for home + pricing + 1 product page (CrowAgent Core). Drive via `npm run test:lighthouse` (calls scripts/run-lighthouse-ci.js). Thresholds match the U-10 spec; tighten only after a baseline is established.",
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "url": [
        "http://localhost:8083/",
        "http://localhost:8083/pricing",
        "http://localhost:8083/crowagent-core"
      ],
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":     ["error", { "minScore": 0.50 }],
        "categories:accessibility":   ["error", { "minScore": 0.95 }],
        "categories:best-practices":  ["error", { "minScore": 0.90 }],
        "categories:seo":             ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
