/* page-styles.css — Per-page styles extracted from inline <style> blocks.
 * Tracking: WEB-AUDIT-092 / DEF-004 (CSP style-src 'unsafe-inline' removal).
 *
 * Each section is keyed by the originating page. Class names are unique enough
 * that loading this stylesheet on every page is safe (no cross-page bleed).
 */

/* ═══════════════════════════════════════════════════════════════════════════
 * 404.html — error page
 * ═════════════════════════════════════════════════════════════════════════ */
.error-page {
  min-height: calc(100vh - 5rem);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: var(--space-12) var(--space-4);
}
.error-content {
  position: relative;
  max-width:calc(480*0.0625rem);
  margin: 0 auto;
}
.error-label {
  font-family: var(--font-display);
  font-size: var(--font-size-xs);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: var(--space-3);
}

/* ═══════════════════════════════════════════════════════════════════════════
 * about.html — founder grid
 * ═════════════════════════════════════════════════════════════════════════ */
.founders-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
  margin-top: var(--space-6);
}
@media (min-width:calc(769*0.0625rem)) {
  .founders-grid {
    grid-template-columns: 1fr 1fr;
  }
}
.founder-card {
  background: var(--surf);
  border:var(--border-hairline) solid var(--border);
  border-radius:1rem;
  padding:var(--space-7) 1.5rem;
  transition: transform 0.2s, border-color 0.2s;
}
.founder-card:hover {
  transform: translateY(-3px);
  border-color: var(--border2);
}
.founder-initials {
  width:calc(64*0.0625rem);
  height:calc(64*0.0625rem);
  border-radius: 50%;
  background: var(--teal);
  color: var(--bg);
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-weight: 800;
  font-size:var(--font-size-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1rem;
}
.founder-name {
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-size:var(--font-size-md);
  font-weight: 700;
  color: var(--cloud);
  text-align: center;
  margin-bottom: var(--space-1);
}
.founder-title {
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-size:var(--font-size-sm);
  font-weight: 600;
  color: var(--teal);
  text-align: center;
  margin-bottom: var(--space-2);
}
.founder-tagline {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size:var(--font-size-base);
  font-style: italic;
  color: var(--steel);
  text-align: center;
  margin-bottom: var(--space-4);
  line-height: 1.6;
}
.founder-bio {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size:var(--font-size-base);
  color: var(--mist);
  line-height: 1.75;
  margin-bottom: var(--space-4);
  text-align: start;
  max-width: 48ch;
  margin-inline-start: auto;
  margin-inline-end: auto;
  hyphens: none;
  word-break: normal;
  overflow-wrap: break-word;
}
.founder-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-size:var(--font-size-sm);
  font-weight: 600;
  color: var(--teal);
  text-decoration: none;
  transition: opacity 0.2s;
}
.founder-link:hover { opacity: 0.8; }

/* ═══════════════════════════════════════════════════════════════════════════
 * blog/index.html — article index page
 * ═════════════════════════════════════════════════════════════════════════ */
.blog-hero {
  padding:7.5rem 0 3.75rem;
  text-align: center;
}
.blog-hero .section-label {
  color: var(--teal);
  font-family: 'Inter', sans-serif;
  font-size:var(--font-size-sm);
  font-weight: 600;
  letter-spacing:0;
  text-transform: uppercase;
  margin-bottom: var(--space-4);
}
.blog-hero h1 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 700;
  color: var(--cloud);
  margin: 0 auto 2.5rem;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  justify-content: center;
  margin-bottom: var(--space-12);
}
.filter-pill {
  background: var(--navy2, var(--surf2));
  color: var(--steel, var(--mist));
  border:var(--border-hairline) solid rgba(138, 157, 184, 0.2);
  border-radius:1.25rem;
  padding:var(--space-2) 1.25rem;
  font-family: 'Inter', sans-serif;
  font-size:var(--font-size-base);
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  min-height:calc(44*0.0625rem);
  display: inline-flex;
  align-items: center;
}
.filter-pill:hover {
  border-color: var(--teal);
  color: var(--cloud);
}
.filter-pill.active {
  background: var(--teal);
  color: var(--obsidian, var(--bg));
  border-color: var(--teal);
  font-weight: 600;
}

.article-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-7);
  max-width:calc(1400*0.0625rem);
  margin: 0 auto;
}
@media (max-width:calc(900*0.0625rem)) {
  .article-grid {
    grid-template-columns: 1fr;
    max-width:calc(560*0.0625rem);
  }
}

.article-card {
  background: var(--navy2, var(--surf2));
  border:var(--border-hairline) solid rgba(138, 157, 184, 0.1);
  border-radius:1rem;
  padding:var(--space-8) 1.75rem;
  transition: transform 0.2s ease, border-color 0.2s ease;
  display: flex;
  flex-direction: column;
}
.article-card:hover {
  transform: translateY(-4px);
  border-color: var(--teal);
}
.article-card a {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.card-badge {
  display: inline-block;
  font-family: 'Inter', sans-serif;
  font-size:var(--font-size-xs);
  font-weight: 600;
  letter-spacing:0;
  text-transform: uppercase;
  color: var(--teal);
  background: var(--teal-dim);
  border:var(--border-hairline) solid var(--teal-25);
  border-radius:0.375rem;
  padding:var(--space-1) 0.625rem;
  margin-bottom: var(--space-4);
  width: fit-content;
}
.card-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--cloud);
  line-height: 1.35;
  margin-bottom: var(--space-3);
}
.card-preview {
  font-family: 'Inter', sans-serif;
  font-size:var(--font-size-base);
  color: var(--steel, var(--mist));
  line-height: 1.65;
  margin-bottom: var(--space-5);
  flex: 1;
}
.card-meta {
  font-family: 'Inter', sans-serif;
  font-size:var(--font-size-sm);
  /* WCAG AA: previous rgba(138,157,184,.6) blended to ~var(--steel-deep) on the
     var(--surface-2) surface and failed at 2.84:1. var(--mist) gives ~5.3:1. */
  color: var(--mist);
}

/* ═══════════════════════════════════════════════════════════════════════════
 * changelog.html — changelog entries
 * ═════════════════════════════════════════════════════════════════════════ */
.changelog-entry { padding:var(--space-6) 0; border-bottom:calc(1*0.0625rem) solid var(--border); }
.changelog-entry:last-child { border-bottom: 0; }
.changelog-meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
  margin-bottom: var(--space-2);
}
.changelog-date {
  color: var(--mist);
  font-family: var(--font-mono), monospace;
  font-size:var(--font-size-sm);
}
.changelog-tag {
  display: inline-block;
  padding:var(--space-0-5) 0.625rem;
  border-radius:var(--radius-full);
  background: var(--teal-12);
  color: var(--teal);
  font-size:var(--font-size-sm);
  font-weight: 600;
}
.changelog-tag.tag-website { background: rgba(91, 200, 255, 0.12); color: var(--sky); }
.changelog-tag.tag-mark { background: rgba(167, 139, 250, 0.12); color: var(--mark); }
.changelog-tag.tag-warn { background: rgba(245, 158, 11, 0.12); color: var(--warn); }
.changelog-entry h3 {
  margin: 0 0 0.75rem;
  font-family: var(--font-display);
  color: var(--cloud);
  font-size:var(--font-size-lg);
}
.changelog-entry ul {
  margin: 0 0 0 1.125rem;
  color: var(--steel);
  line-height: 1.7;
}
.changelog-entry ul li { margin-bottom: var(--space-1); }

/* ═══════════════════════════════════════════════════════════════════════════
 * cookie-preferences.html — cookie preference toggles
 * ═════════════════════════════════════════════════════════════════════════ */
.cookie-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-6);
  padding:var(--space-6);
  background: var(--surf);
  border:var(--border-hairline) solid var(--border);
  border-radius:0.75rem;
  margin-bottom: var(--space-4);
}
.cookie-row-text h3 {
  margin: 0 0 0.5rem;
  font-family: var(--font-display);
  color: var(--cloud);
  font-size:var(--font-size-md);
}
.cookie-row-text p {
  margin: 0;
  color: var(--mist);
  font-size:var(--font-size-base);
  line-height: 1.6;
  max-width:calc(560*0.0625rem);
}
.cookie-toggle {
  position: relative;
  width:calc(48*0.0625rem);
  height:calc(28*0.0625rem);
  border-radius:0.875rem;
  background: var(--surf2);
  border:var(--border-hairline) solid var(--border);
  cursor: pointer;
  flex-shrink: 0;
  transition: background .2s;
}
.cookie-toggle[aria-checked="true"] {
  background: var(--teal);
  border-color: var(--teal);
}
.cookie-toggle[disabled] { cursor: not-allowed; opacity: .6; }
.cookie-toggle-thumb {
  position: absolute;
  top:calc(2*0.0625rem);
  left:calc(2*0.0625rem);
  width:calc(22*0.0625rem);
  height:calc(22*0.0625rem);
  border-radius: 50%;
  background: var(--cloud);
  transition: transform .2s;
}
.cookie-toggle[aria-checked="true"] .cookie-toggle-thumb {
  transform: translateX(1.25rem);
}
.cookie-save-row {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-3);
  margin-top: var(--space-6);
}

/* ═══════════════════════════════════════════════════════════════════════════
 * cookies.html, terms.html — legal content
 * ═════════════════════════════════════════════════════════════════════════ */
.legal-content {
  max-width:calc(960*0.0625rem);
  margin: 0 auto;
  padding: 3rem 1.5rem 4rem;
  font-family: 'Inter', sans-serif;
  color: var(--cloud);
  line-height: 1.7;
}
.legal-content h1 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 800;
  font-size: 2rem;
  margin-bottom: 0.25rem;
  color: var(--cloud);
}
.legal-content .updated {
  font-size: 0.875rem;
  color: var(--steel);
  margin-bottom: 2.5rem;
}
.legal-content h2 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 700;
  font-size: 1.25rem;
  margin: 2rem 0 0.75rem;
  color: var(--cloud);
}
.legal-content p { margin-bottom: 0.75rem; }
.legal-content ul { padding-inline-start: 1.5rem; margin-bottom: 1rem; }
.legal-content li { margin-bottom: 0.5rem; }
/* SF46 Phase 1 2026-05-18 — cta carve-out to keep status-page / contact
   CTAs (`.uptime-cta`, `.sec-uptime-cta`, `.priv-cta`, `.terms-cta`)
   from being forced into prose teal-underline. */
.legal-content a:not([class*="cta"]) {
  color: var(--teal);
  text-decoration: underline;
  text-underline-offset:var(--text-underline-offset);
}
.legal-content a:not([class*="cta"]):hover { text-decoration: underline; }
.legal-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 1rem 0;
  font-size: 0.875rem;
}
.legal-content th {
  text-align: start;
  padding: 0.5rem 0.75rem;
  border-bottom:calc(1*0.0625rem) solid rgba(138, 157, 184, 0.25);
  color: var(--cloud);
  font-weight: 600;
}
.legal-content td {
  padding: 0.5rem 0.75rem;
  border-bottom:calc(1*0.0625rem) solid rgba(138, 157, 184, 0.1);
}
.legal-content code {
  font-size: 0.8rem;
  background: rgba(138, 157, 184, 0.1);
  padding: 0.1rem 0.4rem;
  border-radius:0.1875rem;
}
.legal-content .warning-box {
  border-radius:0.5rem;
  border:var(--border-hairline) solid rgba(245, 158, 11, 0.3);
  background: rgba(245, 158, 11, 0.08);
  padding: 1rem 1.25rem;
  margin: 1rem 0;
}
.legal-content .warning-box strong { color: var(--warn); }
.legal-content .warning-box p { color: var(--warn); }

/* ═══════════════════════════════════════════════════════════════════════════
 * demo.html — Calendly iframe sizing
 * ═════════════════════════════════════════════════════════════════════════ */
.calendly-inline-widget iframe {
  min-height:calc(700*0.0625rem) !important;
  height: 100% !important;
}

/* ═══════════════════════════════════════════════════════════════════════════
 * security.html — security cards grid
 * ═════════════════════════════════════════════════════════════════════════ */
.security-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
  margin-bottom: var(--space-10);
}
.security-grid .sec-card {
  background: var(--surf);
  border:var(--border-hairline) solid var(--border);
  border-radius:1rem;
  padding:var(--space-7) 2rem;
}
.security-grid .sec-card h3 {
  font-family: var(--font-display);
  font-weight: 700;
  font-size:var(--font-size-base);
  color: var(--cloud);
  margin: 0 0 0.625rem;
}
.security-grid .sec-card p {
  font-family: var(--font-body);
  font-size:var(--font-size-base);
  color: var(--steel);
  line-height: 1.7;
  margin: 0;
}
@media (max-width:calc(768*0.0625rem)) {
  .security-grid {
    grid-template-columns: 1fr;
  }
}

/* ═══════════════════════════════════════════════════════════════════════════
 * products/index.html — product hub grid
 * ═════════════════════════════════════════════════════════════════════════ */
.product-hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(17.5rem, 1fr));
  gap: var(--space-6);
  margin-top: var(--space-10);
}
.product-hub-card {
  background: var(--surf);
  border:var(--border-hairline) solid rgba(92, 200, 255, 0.1);
  border-radius:0.75rem;
  padding:var(--space-7) 1.5rem;
  transition: border-color 0.25s, transform 0.25s;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.product-hub-card:hover {
  border-color: var(--teal);
  transform: translateY(-2px);
}
.product-hub-card--disabled {
  opacity: 0.5;
  pointer-events: none;
}
.product-hub-card--disabled:hover {
  border-color: rgba(92, 200, 255, 0.1);
  transform: none;
}
.product-hub-card h3 {
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--cloud);
  margin: 0;
}
.product-hub-card p {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.95rem;
  color: var(--steel, var(--mist));
  line-height: 1.6;
  margin: 0;
  flex: 1;
}
.product-hub-badge {
  display: inline-block;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding:var(--space-1) 0.625rem;
  border-radius:0.25rem;
  width: fit-content;
}
.product-hub-badge--active {
  background: var(--teal-15);
  color: var(--teal);
}
.product-hub-badge--coming {
  background: rgba(194, 255, 87, 0.12);
  color: var(--lime);
}
.product-hub-badge--future {
  background: rgba(138, 157, 184, 0.15);
  color: var(--steel, var(--mist));
}
.product-hub-badge--pro {
  background: rgba(91, 200, 255, 0.12);
  color: var(--sky);
}
.product-hub-card-link {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--teal);
  text-decoration: none;
  transition: color 0.2s;
  min-height:calc(44*0.0625rem);
  display: inline-flex;
  align-items: center;
}
.product-hub-card-link:hover {
  color: var(--lime);
}
.product-hub-card-link--disabled {
  color: var(--steel, var(--mist));
  cursor: default;
}
.product-hub-card-link--disabled:hover {
  color: var(--steel, var(--mist));
}
.phase-header {
  display: flex;
  align-items: baseline;
  gap: var(--space-3);
  margin-top: var(--space-16);
  margin-bottom: 0;
}
.phase-header h3 {
  font-family: var(--font-display, 'Plus Jakarta Sans', sans-serif);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--cloud);
  margin: 0;
}
.phase-unlock {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.8rem;
  color: var(--steel, var(--mist));
  font-style: italic;
}

/* ═══════════════════════════════════════════════════════════════════════════
 * Stripe-refresh product pages (crowagent-core / crowmark / crowcyber /
 * crowcash / crowesg / csrd) — shared hero polish, demo slot, trust band,
 * five-card related-products override, motion-system class hooks.
 * Tracking: product-pages Stripe-refresh 2026-05-17.
 * ═════════════════════════════════════════════════════════════════════════ */

/* Compact regulatory eyebrow above hero title.
 * Use INSTEAD of the long-form .section-label on product heroes. */
.hero-reg-chip {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size:var(--font-size-xs);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--teal);
  background: var(--teal-dim);
  border:var(--border-hairline) solid rgba(12, 201, 168, 0.28);
  border-radius:var(--radius-pill);
  padding:var(--space-1-5) 0.875rem;
  margin-bottom: var(--space-4);
}
.hero-reg-chip::before {
  content: "";
  width:calc(6*0.0625rem);
  height:calc(6*0.0625rem);
  border-radius: 50%;
  background: var(--teal);
  box-shadow: 0 0 0 0.25rem rgba(12, 201, 168, 0.16);
  flex-shrink: 0;
}

/* Tightened hero subline — narrower max, fewer characters per line. */
.hero-sub-tight {
  max-width:calc(640*0.0625rem);
  margin-inline-start: auto;
  margin-inline-end: auto;
}

/* 16:9 demo placeholder slot. Real video drops in via the
 * data-demo-slot="<product>" hook. Keep dark, framed, subtle gradient. */
.hero-demo-slot {
  /* SF46 batch #2 2026-05-20 — z-index bumped 2 → 10 per founder directive
     so the slot owns its stacking context above sibling .f10-summary-box
     and parallax neighbours. Pair with .f10-summary-box margin-top: var(--space-12)
     on crowagent-core.html to prevent overlap. */
  position: relative;
  display: block;
  width: min(100%, 60rem);
  margin:var(--space-7) auto 0;
  aspect-ratio: 16 / 9;
  border-radius:1rem;
  border:var(--border-hairline) solid var(--border2);
  background:
    radial-gradient(120% 80% at 50% 0%, var(--teal-12), transparent 60%),
    linear-gradient(180deg, rgba(13, 40, 71, 0.85) 0%, rgba(10, 31, 58, 0.92) 100%);
  box-shadow:
    0 2rem 4rem -28px rgba(0, 0, 0, 0.55),
    inset 0 1px 0 var(--white-04);
  overflow: hidden;
  z-index: var(--z-content);
}
.hero-demo-slot__chrome {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  padding:var(--space-3) 1rem;
  border-bottom:calc(1*0.0625rem) solid var(--border2);
  background: rgba(4, 14, 26, 0.45);
}
.hero-demo-slot__dot {
  width:calc(10*0.0625rem);
  height:calc(10*0.0625rem);
  border-radius: 50%;
  background: var(--mist);
  opacity: 0.55;
}
.hero-demo-slot__label {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 600;
  font-size:var(--font-size-sm);
  color: var(--mist);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0 1.5rem;
  gap: var(--space-2);
}
.hero-demo-slot__label::before {
  content: "";
  width:calc(64*0.0625rem);
  height:calc(64*0.0625rem);
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, rgba(12, 201, 168, 0.32) 0%, var(--teal-12) 60%, transparent 100%);
  border:var(--border-hairline) solid rgba(12, 201, 168, 0.55);
  display: grid;
  place-items: center;
  position: relative;
  box-shadow: 0 0 0 0 rgba(12, 201, 168, 0.45);
  animation: heroDemoPulse 2.6s var(--ease-standard) infinite;
}
.hero-demo-slot__label::after {
  content: "";
  position: absolute;
  width: 0; height: 0;
  border-style: solid;
  border-width:calc(11*0.0625rem) 0 0.6875rem 1.0625rem;
  border-color: transparent transparent transparent var(--teal);
  top: calc(50% - 0.6875rem - 0.5rem);
  left: calc(50% - 0.375rem);
  filter: drop-shadow(0 0 0.375rem rgba(12, 201, 168, 0.45));
}
@keyframes heroDemoPulse {
  0%   { box-shadow: 0 0 0 0 rgba(12, 201, 168, 0.45); }
  70%  { box-shadow: 0 0 0 1.375rem rgba(12, 201, 168, 0); }
  100% { box-shadow: 0 0 0 0 rgba(12, 201, 168, 0); }
}
.hero-demo-slot:hover .hero-demo-slot__label::before {
  background: radial-gradient(circle at 50% 50%, rgba(12, 201, 168, 0.55) 0%, rgba(12, 201, 168, 0.22) 60%, transparent 100%);
  transform: scale(1.06);
  transition: transform 0.25s ease, background 0.25s ease;
}
@media (prefers-reduced-motion: reduce) {
  .hero-demo-slot__label::before { animation: none; }
}
.hero-demo-slot__label > .hero-demo-slot__hint {
  font-weight: 400;
  font-size:var(--font-size-sm);
  letter-spacing: 0.02em;
  text-transform: none;
  color: var(--steel);
  max-width: 38ch;
}

/* Trust-signal chip band — compact regulatory anchors below hero. */
.trust-chip-band {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  justify-content: center;
  margin:1.125rem auto 0;
  max-width:calc(920*0.0625rem);
  padding: 0 0.5rem;
}
.trust-chip {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size:var(--font-size-xs);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--steel);
  background: rgba(13, 40, 71, 0.55);
  border:var(--border-hairline) solid var(--border2);
  border-radius:var(--radius-pill);
  padding:var(--space-1-5) 0.75rem;
  min-height:calc(28*0.0625rem);
}
/* SF46 batch #2 2026-05-20 — middle-dot separator between trust chips
   (founder Stripe/Apple-grade premium polish directive). */
.trust-chip-band .trust-chip:not(:last-child)::after {
  content: '·';
  margin-inline-start: var(--space-2);
  color: var(--mist);
  opacity: 0.7;
  font-weight: 400;
}
.trust-chip strong {
  color: var(--cloud);
  font-weight: 700;
}

/* Five-card related-products override — used on every product page so each
 * page links to the other five. Container already auto-fits via styles.css;
 * here we tighten the card head/arrow treatment for Stripe-grade polish. */
.f10-related-products--five {
  grid-template-columns: repeat(auto-fit, minmax(12.5rem, 1fr));
  gap: var(--space-3);
}
.f10-related-card__arrow {
  position: absolute;
  top:calc(18*0.0625rem);
  right:calc(16*0.0625rem);
  width:calc(22*0.0625rem);
  height:calc(22*0.0625rem);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--teal);
  opacity: 0.7;
  transition: transform 0.2s, opacity 0.2s;
}
.f10-related-card:hover .f10-related-card__arrow {
  transform: translateX(3px);
  opacity: 1;
}
.f10-related-card__accent {
  display: inline-block;
  width:calc(24*0.0625rem);
  height:calc(2*0.0625rem);
  border-radius:0.125rem;
  background: var(--teal);
  margin-bottom: var(--space-2);
  opacity: 0.85;
}
.f10-related-card--mark .f10-related-card__accent { background: var(--mark); }
.f10-related-card--cyber .f10-related-card__accent { background: var(--sky); }
.f10-related-card--cash .f10-related-card__accent { background: var(--lime); }
.f10-related-card--esg .f10-related-card__accent { background: var(--success-bright); }
.f10-related-card--csrd .f10-related-card__accent { background: var(--sight); }
.f10-related-card--core .f10-related-card__accent { background: var(--teal); }

/* Motion-system class hooks (JS wired separately by motion-system agent).
 * Provide a safe, non-blocking baseline so the page renders cleanly even
 * before any IntersectionObserver / parallax controller exists. */
.ms-reveal {
  opacity: 1;
  transform: none;
}
@media (prefers-reduced-motion: no-preference) {
  /* When JS controller attaches data-ms-reveal-ready, fade in.
   * Until then, content is fully visible (defensive default). */
  .ms-reveal[data-ms-reveal-pending] {
    opacity: 0;
    transform: translateY(0.75rem);
    transition: opacity 0.6s var(--ease-out),
                transform 0.6s var(--ease-out);
    will-change: opacity, transform;
  }
  .ms-reveal[data-ms-reveal-in] {
    opacity: 1;
    transform: none;
  }
}
.ms-card-lift {
  transition: transform 0.22s var(--ease-out),
              border-color 0.22s,
              box-shadow 0.22s;
  will-change: transform;
}
@media (hover: hover) and (prefers-reduced-motion: no-preference) {
  .ms-card-lift:hover {
    transform: translateY(-3px);
    box-shadow: 0 0.875rem 2rem -16px rgba(0, 0, 0, 0.55);
  }
}
.ms-parallax-soft {
  will-change: transform;
}
@media (prefers-reduced-motion: reduce) {
  .ms-reveal,
  .ms-card-lift,
  .ms-parallax-soft {
    transition: none !important;
    transform: none !important;
    opacity: 1 !important;
  }
}

/* Sectional vertical rhythm aligned to the 8-step spacing scale.
 * Applies only when sections use the new `.product-section` class so we
 * don't regress existing `.section-padding` on other pages. */
.product-section {
  padding-top: var(--space-20);
  padding-bottom: var(--space-20);
}
@media (max-width:calc(768*0.0625rem)) {
  .product-section {
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }
}

