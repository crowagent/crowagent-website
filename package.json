  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/crowagent/crowagent-website/issues"
  },
  "homepage": "https://github.com/crowagent/crowagent-website#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "csso-cli": "^4.0.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "purgecss": "^8.0.0",
    "satori": "^0.12.2",
    "sharp": "^0.34.5",
    "stripe": "^17.5.0",
    "terser": "^5.46.1",
    "tsx": "^4.19.2"
  }
