node_modules/
coverage/

# WEB-AUDIT-146 / CLAUDE.md §17 — site is on Cloudflare Pages (PRs #132/#133).
# .vercel/ is a legacy artifact from the pre-April-2026 Vercel deploy and must
# never be re-introduced (cross-repo `vercel --prod` could redeploy the wrong
# project to crowagent.ai). Ignore the directory entirely — no exceptions.
.vercel/
.wrangler/
.claude/

# CODE-AUDIT-022 — minified bundles are build outputs (per `npm run build:js`),
# not sources. Keep them out of the working tree once the CI/CDN build is wired
# up. Until then, the existing committed `scripts.min.js` / `styles.min.css`
# remain (CF Pages "no-build" deploy posture per CLAUDE.md §17).
# scripts.min.js
# styles.min.css

# CODE-AUDIT-024 — debug/test artefacts must never be deployed by CF Pages
audit_website.txt
test_website.txt
test_website_fixed.txt
DEBUG-REPORT-*.md
E2E-AUDIT-REPORT-*.md
LIGHT-THEME-DEPLOYMENT-CHECKLIST.md
WEBSITE-DEEP-AUDIT.md
verify-light-theme.js

# CODE-AUDIT-048 — test/coverage output dirs (CF Pages would otherwise serve them)
playwright-report/
test-results/
audit-results/
index-temp.html

# Secrets — DEF-002 / DEF-003 — never commit any env file
.env
.env.*
.env.local
.env*.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local

# OG image generator font cache (re-fetched on each clean build)
.cache/
