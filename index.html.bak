<section class="sectors reveal sf17-reveal section-tone-0" id="sectors" aria-label="Who we serve, sectors">
  <div class="wrap container-standard">
    <div class="sh">
      <div class="sh-label">Who we serve</div>
      <h2>Twelve sectors. Six products. One operating spine.</h2>
      <p class="steps-sub">Every sector below maps to a primary CrowAgent product and an explicit regulatory anchor. The free funnel column shows the no-account-required entry point we offer that team.</p>
    </div>
    <div class="sector-grid sectors-grid sf10-sectors-grid" id="f10-sector-grid">

      <!-- 1. SME Finance / Owner-managed Business (Cash quick-win) -->
