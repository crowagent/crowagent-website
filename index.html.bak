<!-- DOMPurify for XSS sanitization (DEF-007) — defer keeps execution order before scripts.min.js (perf 2026-05-03)
     DEF-007 / DEF-018 / DEF-025 2026-05-09 fix: dual-hash integrity (sha384 + sha512).
     SHA-384 verified vs cdnjs-served bytes locally (21496 B); SHA-512 mirrors the
     cdnjs API's canonical SRI hash for purify.min.js@3.1.6. Browsers accept the
     script if EITHER hash matches — protects us if a future browser drops SHA-384
     without weakening the integrity check. -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.1.6/purify.min.js" integrity="sha384-+VfUPEb0PdtChMwmBcBmykRMDd+v6D/oFmB3rZM/puCMDYcIvF968OimRh4KQY9a sha512-jB0TkTBeQC9ZSkBqDhdmfTv1qdfbWpGE72yJ/01Srq6hEzZIz2xkz1e57p9ai7IeHMwEG7HpzG6NdptChif5Pg==" crossorigin="anonymous" defer></script>
