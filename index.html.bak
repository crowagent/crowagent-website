<body class="page-home">
<canvas id="ca-particles" class="ca-particles" aria-hidden="true"></canvas>
<a href="#main-content" class="skip-link sr-only">Skip to main content</a>

<!-- G1 2026-05-20 — Scroll progress bar (restored after 3-day absence).
     Uses modern scroll-driven animation timeline (Chrome 115+, FF 110+) with
     a JS fallback for older browsers. Fixed top-of-viewport teal bar that
     fills L→R as the page scrolls. Above-cookie z-index. -->
<div id="scroll-progress" class="scroll-progress" role="progressbar"
     aria-label="Page scroll progress" aria-valuemin="0" aria-valuemax="100"></div>

<div class="announce-bar" id="announce-bar" role="banner" aria-label="Promotional announcement" aria-live="polite">
  <div class="wrap">
    <span class="ab-dot"></span>
    <span class="ab-text">Now live &nbsp;·&nbsp; 14-day free trial &nbsp;·&nbsp; No credit card required</span>
    <a href="https://app.crowagent.ai/signup" class="ab-cta">Start free trial</a>
    <button class="ab-close" data-action="dismiss-bar" aria-label="Dismiss announcement">×</button>
  </div>
</div>

<!-- NAV — injected by js/nav-inject.js (single source of truth) -->
<header id="ca-nav" class="sv-nav" role="banner"></header>

<main  tabindex="-1" id="main-content" role="main" class="pmb-host pmb-grid pmb-scan-line">
<section class="hero section-tone-0 hero-has-backdrop hero-hud hero-split-active" role="banner" id="hero">
  <!-- SF13 2026-05-17 Live HUD over Earth — founder-picked Option 3.
       Restores the user's original premium night-Earth image (UK city lights
       + embedded compliance icons + connection lines, 1822×863). On top:
       a Bloomberg-terminal-style HUD with a live countdown to the
       27 April 2026 Cyber Essentials v3.3 Danzell deadline, 5 orbiting
       compliance badges, animated SVG pulse paths flowing toward the UK
       cluster, and a bottom-left metrics ticker. All HUD elements respect
       prefers-reduced-motion. The Earth opacity is 0.92 (vs option-3's
       default 0.50) per founder direction to make Earth clearly visible. -->
  <div class="hero-backdrop hero-bg-earth" aria-hidden="true"></div>
  <div class="hero-bg-vignette" aria-hidden="true"></div>
  <div class="hero-bg-grid" aria-hidden="true"></div>

  <!-- Live countdown panel — top right -->
  <aside class="hero-hud-counter" aria-label="Cyber Essentials v3.3 Danzell deadline countdown">
    <div class="hhc-label">Deadline · v3.3</div>
    <div class="hhc-countdown">
      <span class="hhc-number" id="sf13-count-number">19</span>
      <span class="hhc-unit">days</span>
    </div>
    <div class="hhc-caption">until <strong>Cyber Essentials v3.3 Danzell</strong>, 27 Apr 2026</div>
  </aside>

  <!-- Orbiting compliance badges — desktop only (hidden &lt;980px in CSS) -->
  <div class="hero-orbit-stage" aria-hidden="true">
    <span class="hob b0"><span class="hob-ico">✓</span>Cyber Essentials v3.3</span>
    <span class="hob b1 alt"><span class="hob-ico">✓</span>PPN 002</span>
    <span class="hob b2 mut"><span class="hob-ico">Δ</span>MEES proposed 2028</span>
    <span class="hob b3"><span class="hob-ico">I</span>Omnibus I</span>
    <span class="hob b4 alt"><span class="hob-ico">v</span>EFRAG VSME 2024</span>
  </div>

  <!-- Pulse path SVG -->
  <svg class="hero-hud-pulse" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <path id="sf13-pulse-path" d="M 1420 120 Q 1100 220 820 320 T 460 360" />
    </defs>
    <use href="#sf13-pulse-path" class="hhp-line" />
    <circle r="4" class="hhp-dot">
      <animateMotion dur="6s" repeatCount="indefinite" rotate="auto"><mpath href="#sf13-pulse-path" /></animateMotion>
    </circle>
    <circle r="3" class="hhp-dot" opacity="0.6">
      <animateMotion dur="6s" begin="-2s" repeatCount="indefinite" rotate="auto"><mpath href="#sf13-pulse-path" /></animateMotion>
    </circle>
    <circle r="2.5" class="hhp-dot" opacity="0.35">
      <animateMotion dur="6s" begin="-4s" repeatCount="indefinite" rotate="auto"><mpath href="#sf13-pulse-path" /></animateMotion>
    </circle>
  </svg>

  <!-- Bottom-left UK SME metrics ticker -->
  <aside class="hero-hud-metrics" aria-label="UK SME compliance metrics">
    <div class="hhm-head">UK SME signal</div>
    <div class="hhm-row">
      <div class="hhm-label">UK SMEs</div>
      <div class="hhm-value"><span data-sf13-target="5500000" data-sf13-format="abbr">0</span></div>
    </div>
    <div class="hhm-row">
      <div class="hhm-label">CE certs / year</div>
      <div class="hhm-value"><span data-sf13-target="37000">0</span><span class="hhm-suffix">+</span></div>
    </div>
    <div class="hhm-row">
      <div class="hhm-label">SME late payment</div>
      <div class="hhm-value">£<span data-sf13-target="26" data-sf13-format="bn">0</span><span class="hhm-suffix">B</span></div>
    </div>
  </aside>

  <!-- Bottom-right ops status panel -->
  <aside class="hero-hud-signal" aria-label="Platform status">
    <div class="hhs-head">Status · ops</div>
    <div class="hhs-row"><span>IASME feed</span><span class="hhs-ok">● online</span></div>
    <div class="hhs-row"><span>Brevo mail</span><span class="hhs-ok">● online</span></div>
    <div class="hhs-row"><span>Stripe live</span><span class="hhs-ok">● online</span></div>
    <div class="hhs-row"><span>Supabase</span><span class="hhs-ok">● online</span></div>
    <div class="hhs-row"><span>Latency</span><span class="hhs-v">42 ms</span></div>
  </aside>
  <!-- PH1.1 2026-05-20 — Sovereign hero structural primitives.
       sv-container--wide = canonical wrap with auto inline margin + gutter.
       sv-grid--lg        = auto-fit two-column grid (min 400px each → split-
                            layout at desktop, collapses to single column on
                            tablet/mobile, no manual @media queries needed).
       hero-inner kept as a hook for legacy GSAP/JS (cinematic-init,
       sf25-interactions) — sovereign classes drive the layout.            -->
  <div class="sv-container sv-container--wide wrap container-wide"><!-- hero: container-wide -->
    <!-- GEO.A 2026-05-20 — RECONCILIATION per Principal Architect audit.
         Was: sv-grid sv-grid--lg (2-column split: copy left, dashboard right).
              Produced 258px drift between H1 centre (786) and CTA centre (528).
         Now: sv-stack sv-stack--align-center (single-column centred hero).
              H1 + sub + CTAs all share the SAME centre X. Drift target ≤10px.
         The dashboard preview previously in .hero-col-visual is already
         showcased in the cinematic walkthrough + products bento — no info
         loss, no duplication. Pure Apple/Stripe "one message, centred" hero. -->
    <div class="hero-inner sv-stack sv-stack--align-center sv-stack--gap-8">
      <div class="hero-col-copy sv-stack sv-stack--gap-6 sv-stack--align-center">
        <!-- VIS.B4 2026-05-20 — Single eyebrow label (Stripe pattern).
             Was 2 stacked pill chips (status + countdown) which (a) created
             mobile-overflow bug at 390px and (b) read as Notion-2018, not
             Stripe-2026. Now: ONE 11px small-caps text label with a dot.
             The countdown panel #hero-countdown-panel is preserved (hidden,
             aria-only) so existing MEES countdown JS still has its hook. -->
        <div class="hero-eyebrow hero-eyebrow-static sv-eyebrow" id="hero-live-badge" role="status" aria-label="Platform status">
          <span class="hw-dot" aria-hidden="true"></span>
          <span class="hero-eyebrow-text">
            Now in force&nbsp;&middot;&nbsp;Cyber Essentials v3.3 Danzell<span class="hero-eyebrow-suffix">&nbsp;&middot;&nbsp;27 Apr 2026</span>
          </span>
        </div>
        <!-- Hidden countdown anchor for legacy MEES countdown JS hook. -->
        <div id="hero-countdown-panel" role="status" aria-live="polite" data-band-c-countdown-sentence data-persona-eyebrow hidden><span id="countdown-text"><span id="countdown-days" data-band-c-countdown></span> <span id="countdown-label">days until the proposed MEES Band C date</span></span></div>
        <!-- STATIC H1 — single permanent headline. Per-segment rotation removed at H1 level per spec. -->
        <h1 class="hero-headline hero-split-h1">
          UK compliance, <em>quantified</em>.<br>
          Not guessed.
        </h1>
        <!-- HP-PREMIUM 2026-05-20 — sub tightened to Stripe-grade ≤20 words,
             anchored on the saved value prop (affordable compliance +
             sustainability for UK SMEs · cited to statute · no consultancy
             fee). The product list moves to the dedicated grid below; the
             hero no longer dumps every framework name. -->
        <p class="hero-sub hero-split-sub">
          Affordable compliance and sustainability intelligence for UK SMEs &mdash; cited to statute, built to remove the manual work.
        </p>
        <!-- VIS.B3 2026-05-20 — Persona switcher + per-segment penalty banners
             + per-segment CTA spans LIFTED OUT of the hero. They now live in a
             dedicated .hp-audience-band section below the sector marquee. The
             hero retains only: eyebrow → H1 → sub → 2 universal CTAs →
             credibility chip → trust strip → authority bar. This collapses the
             hero from ~1859px → ~900px and brings the CTAs above the fold,
             per the Stripe/Apple research benchmark (single focused message,
             no in-hero persona switcher). -->
        <div class="hero-btns hero-split-btns">
          <a href="https://app.crowagent.ai/signup"
             class="sv-btn sv-btn--lg sv-btn--primary"
             aria-label="Start your 14-day free trial, no credit card required">
            Start free trial
          </a>
          <a href="https://calendly.com/crowagent-platform/30min"
             class="sv-btn sv-btn--lg sv-btn--ghost"
             aria-label="Book a 30-minute product demo">
            Book a demo &rarr;
          </a>
        </div>
        <p class="cta-no-card">No credit card required · 14-day free trial · Cancel anytime</p>
        <!-- G2 2026-05-20 — Credibility chip. Stripe/Apple pattern: tangible
             provenance signal directly beneath main CTAs. Uses the .sv-badge
             sovereign primitive. Sentence-case, unverifiable-claim free. -->
        <!-- PE-ROLE 2026-05-20: pre-launch, no customer claims. Credibility
             chip anchors on the FOUNDER-side truth (UK-built, statute-cited)
             instead of fake customer testimony. -->
        <div class="sv-badge sv-badge--accent hero-credibility-chip" role="note" aria-label="UK-built and cited to statute">
          <svg class="sv-icon sv-icon--sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 7 9 18l-5-5"/></svg>
          <span>UK-built. Cited to statute. Affordable for SMEs.</span>
        </div>
        <!-- WEBSITE-FIX-001 WS-7.1: canonical 5-badge trust set used identically across nav-inject + hero. Distinguishes transport (TLS 1.3) from at-rest (AES-256). 99.5% uptime moved to status-page link in footer. -->
        <div class="hero-trust">
          <div class="ht-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>AES-256 at rest</div>
          <div class="ht-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>TLS 1.3 in transit</div>
          <div class="ht-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>GDPR compliant</div>
          <div class="ht-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>UK data residency</div>
          <div class="ht-item" title="We follow ISO 27001 controls. Formal certification planned for Phase 2."><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>ISO 27001 aligned</div>
          <!-- G-Cloud badge — uncomment when listed on G-Cloud 16 -->
          <!-- TO ENABLE: Remove comment tags when G-Cloud 16 listing is live -->
          <!--
          <div class="ht-item is-hidden" id="gcloud-badge" hidden>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            G-Cloud 16 listed
          </div>
          -->
        </div>

        <!-- ENH 2 — Apple-style statute-mapped authority bar.
             Lists the UK regulators / framework bodies CrowAgent's engines are
             mapped to. Factual regulatory citation, NOT customer endorsement —
             compliant with UK CPRs 2008 reg 5. SF30 2026-05-18: relocated into
             .hero-col-copy below .hero-trust per spec section 8. -->
        <div class="sf18-trust-bar" aria-label="Regulatory frameworks CrowAgent maps to">
          <span class="sf18-trust-eyebrow ca-eyebrow">Statute-mapped to</span>
          <div class="sf18-trust-track" role="list">
            <span class="sf18-trust-item" role="listitem"><span class="sf18-trust-label">NCSC</span><span class="sf18-trust-sub">Cyber Essentials</span></span>
            <span class="sf18-trust-divider" aria-hidden="true"></span>
            <span class="sf18-trust-item" role="listitem"><span class="sf18-trust-label">IASME</span><span class="sf18-trust-sub">Certification body</span></span>
            <span class="sf18-trust-divider" aria-hidden="true"></span>
            <span class="sf18-trust-item" role="listitem"><span class="sf18-trust-label">Cabinet Office</span><span class="sf18-trust-sub">PPN 002</span></span>
            <span class="sf18-trust-divider" aria-hidden="true"></span>
            <span class="sf18-trust-item" role="listitem"><span class="sf18-trust-label">MHCLG</span><span class="sf18-trust-sub">EPC register</span></span>
            <span class="sf18-trust-divider" aria-hidden="true"></span>
            <span class="sf18-trust-item" role="listitem"><span class="sf18-trust-label">EFRAG</span><span class="sf18-trust-sub">VSME 2024</span></span>
            <span class="sf18-trust-divider" aria-hidden="true"></span>
            <span class="sf18-trust-item" role="listitem"><span class="sf18-trust-label">ICO</span><span class="sf18-trust-sub">Data controller</span></span>
          </div>
        </div>
      </div><!-- /.hero-col-copy -->

      <!-- GEO.A 2026-05-20 — .hero-col-visual REMOVED per geometric audit.
           The dashboard mockup it contained (01-dashboard-dark-framed.png)
           is already showcased in:
             1. The cinematic walkthrough section right below (full-screen,
                with GSAP Ken Burns pan, 28-second loop)
             2. The products bento (CrowAgent Core card uses
                app.crowagent.ai_crowagentcore_home.png — same product UI)
           Keeping the right-column hero visual created a 2-column split
           that pinned the H1 left of centre (786px) while CTAs sat left-
           aligned (528px) = 258px drift. Single centred hero, period. -->
    </div>
    <!-- END HERO INNER -->

  </div>
</section><!-- end #hero -->

<!-- AF.6 2026-05-20 — SME sector logo marquee. Stripe/Apple credibility
     band immediately beneath the hero. Sector-representing SVG icons
     (TechCorp / GreenLogistics / RetailUK / FinanceUK / ConstructionUK /
     EnergyUK / PropertyUK / HealthTechUK) tinted via currentColor.
     The track is duplicated for seamless infinite scroll (-50% loop). -->
<!-- PE-ROLE 2026-05-20: pre-launch reconciliation. No customer or partner
     claims — these are sector representations only. Heading + aria-label
     frame the marquee as the target market CrowAgent serves, not
     endorsements from existing customers/partners (we have none yet). -->
<aside class="sv-marquee sv-marquee--sectors" aria-label="UK SME sectors CrowAgent is built for">
  <p class="sv-marquee__heading">Built for UK SMEs across these sectors</p>
  <div class="sv-marquee__track" role="list">
