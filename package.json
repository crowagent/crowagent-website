{
  "name": "crowagent-website",
  "version": "1.0.0",
  "description": "",
  "main": "scripts.js",
  "scripts": {
    "build:css": "node scripts/build-css.js",
    "build:css:legacy": "csso styles.css --output styles.min.css",
    "build:js": "terser scripts.js --compress --mangle --output scripts.min.js",
    "build:og": "node scripts/generate-og-images.js",
    "build:og:force": "node scripts/generate-og-images.js --force",
    "build:og:check": "node scripts/generate-og-images.js --check",
    "build:webp": "node scripts/build-webp.js --rewrite-html",
    "build:webp:check": "node scripts/build-webp.js --check",
    "build": "npm run build:webp && npm run build:css && npm run build:js && npm run build:og",
    "test": "jest",
    "test:responsive": "playwright test tests/responsive.spec.js",
    "sync-pricing": "tsx scripts/sync-pricing-from-stripe.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crowagent/crowagent-website.git"
  },
  "keywords": [],
