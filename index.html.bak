        <a class="hp-framework-link" href="/crowmark" aria-label="Learn more about CrowMark's PPN 002 coverage">Explore CrowMark <span aria-hidden="true">&rarr;</span></a>
      </li>
      <li class="hp-framework-row" data-product="csrd">
        <span class="hp-framework-mark">CSRD Omnibus I</span>
        <span class="hp-framework-cite sv-text-tertiary">Directive (EU) 2026/470</span>
        <p class="hp-framework-desc sv-text-secondary">Free Omnibus I applicability test &mdash; employees, turnover, and group-scope thresholds in under a minute.</p>
        <a class="hp-framework-link" href="/csrd" aria-label="Open the free CSRD Checker tool">Free CSRD Checker <span aria-hidden="true">&rarr;</span></a>
      </li>
      <li class="hp-framework-row" data-product="core">
        <span class="hp-framework-mark">MEES Band C 2028</span>
        <span class="hp-framework-cite sv-text-tertiary">SI 2015/962 reg 38</span>
        <p class="hp-framework-desc sv-text-secondary">Rateable-value penalty up to &pound;150K modelled per property, three retrofit scenarios, HM Treasury NPV.</p>
        <a class="hp-framework-link" href="/crowagent-core" aria-label="Learn more about CrowAgent Core's MEES coverage">Explore CrowAgent Core <span aria-hidden="true">&rarr;</span></a>
      </li>
      <li class="hp-framework-row" data-product="esg">
        <span class="hp-framework-mark">EFRAG VSME 2024</span>
        <span class="hp-framework-cite sv-text-tertiary">Module B Basic + Module C</span>
        <p class="hp-framework-desc sv-text-secondary">Voluntary SME standard mapped to ESG report. Get ahead of supply-chain disclosure requests.</p>
        <a class="hp-framework-link" href="/tools/vsme-materiality-light" aria-label="Open the free VSME materiality light tool">Open free tool <span aria-hidden="true">&rarr;</span></a>
      </li>
    </ul>
  </div>
</section>

<!-- E-HOME 10-10 (2026-05-10): the placeholder rotator section that
     previously sat here was removed at user direction. Its content was
     three illustrative-scenario placeholders that duplicated the
     narrative space already covered by the U-27a "Compliance frameworks
     we cover" section above. Per UK CPRs 2008 reg 5 the rotator copy
     was non-actionable until verified customer attestations exist;
     rather than maintain a placeholder block, it has been deleted and
     the section-tone alternation rebalanced (reg-strip-section moved
     from section-tone-1 to section-tone-0 to preserve the 0/1 rhythm
     after the removal). -->
<!-- ── REGULATORY REFERENCE STRIP — WP-WEB-003 ──
     P8 2026-05-17: converted from scrolling marquee to a static centered
     chip row per Stripe /customers precedent. role="marquee" dropped (not a
     valid ARIA role); role="list" on container, role="listitem" on chips.
     Layout / animation override in styles.css P8 block. -->
<section class="reg-strip-section section-tone-0 reveal sf14-marquee" aria-label="Regulatory references container">
<!-- SF14 2026-05-17: restored the scrolling compliance ticker from live
     crowagent.ai (was previously converted to a static chip row in P8).
     6 unique mqi items + a duplicated set marked aria-hidden so the marquee
     loops seamlessly (translateX(-50%) snaps back invisibly). Hover pause
     + prefers-reduced-motion halt. -->
<div class="reg-strip" role="marquee" aria-label="Regulatory references">
  <div class="mq">
    <div class="mq-t" role="list">
      <div class="mqi" role="listitem"><span class="mq-d"></span>MEES SI 2015/962 reg 38 · £150K cap</div>
      <div class="mqi" role="listitem"><span class="mq-d"></span>PPN 002 · 10% social value</div>
      <div class="mqi" role="listitem"><span class="mq-d"></span>Cyber Essentials v3.3 Danzell</div>
      <div class="mqi" role="listitem"><span class="mq-d"></span>Late Payment Act 1998 · BoE+8%</div>
      <div class="mqi" role="listitem"><span class="mq-d"></span>CSRD Omnibus I (EU 2026/470)</div>
      <div class="mqi" role="listitem"><span class="mq-d"></span>EFRAG VSME 2024</div>
      <!-- SF14: aria-hidden duplicate set for seamless translateX(-50%) loop -->
      <div class="mqi" aria-hidden="true"><span class="mq-d"></span>MEES SI 2015/962 reg 38 · £150K cap</div>
      <div class="mqi" aria-hidden="true"><span class="mq-d"></span>PPN 002 · 10% social value</div>
      <div class="mqi" aria-hidden="true"><span class="mq-d"></span>Cyber Essentials v3.3 Danzell</div>
      <div class="mqi" aria-hidden="true"><span class="mq-d"></span>Late Payment Act 1998 · BoE+8%</div>
      <div class="mqi" aria-hidden="true"><span class="mq-d"></span>CSRD Omnibus I (EU 2026/470)</div>
      <div class="mqi" aria-hidden="true"><span class="mq-d"></span>EFRAG VSME 2024</div>
    </div>
  </div>
</div>
</section>
